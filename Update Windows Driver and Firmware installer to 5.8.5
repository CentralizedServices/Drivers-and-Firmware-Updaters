function Write-ProtocolHandler
{
    $Content = @'
[CmdletBinding()]
param ([string]$ProtocolArg)

$BasePath      = "C:\ProgramData\i3"
$LogPath       = Join-Path $BasePath "logs"
$LogFile       = Join-Path $LogPath "Request-DriverInstall.log"
$TaskName      = "i3_DriverInstallAndRestart"
$ScriptName    = "Request-DriverInstall"
$ScriptVersion = "1.0.0"
$InternalExit  = 0

function Write-Log
{
    param ([string]$Message, [string]$Level = "INFO")
    $Line = "{0} [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level.ToUpper(), $Message
    try
    {
        if (-not (Test-Path -Path $LogPath)) { New-Item -Path $LogPath -ItemType Directory -Force | Out-Null }
        Add-Content -Path $LogFile -Value $Line -ErrorAction Stop
    }
    catch { }
}

try
{
    Write-Log "============================================================"
    Write-Log ("Script: {0} v{1}" -f $ScriptName, $ScriptVersion)
    Write-Log ("User: {0}" -f [Security.Principal.WindowsIdentity]::GetCurrent().Name)
    Write-Log ("ProtocolArg: {0}" -f $ProtocolArg)
    Write-Log ("Triggering SYSTEM task: {0}" -f $TaskName)
    $Task = Get-ScheduledTask -TaskName $TaskName -ErrorAction Stop
    Start-ScheduledTask -InputObject $Task -ErrorAction Stop
    Write-Log "Task trigger succeeded." "SUCCESS"
