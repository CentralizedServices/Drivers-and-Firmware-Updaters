}

function Send-UserToast
{
    param ([string]$Title, [string]$Body, [string]$Suffix = "Msg")

    # WinRT requires an interactive session — skip when SYSTEM
    $CurrentUser = [Security.Principal.WindowsIdentity]::GetCurrent().Name
    if ($CurrentUser -match '^(NT AUTHORITY\\SYSTEM|SYSTEM)$')
    {
        Write-Log ("Send-UserToast skipped ({0}): SYSTEM has no interactive session. Suffix: {1}" -f $CurrentUser, $Suffix) "INFO"
        return
    }

    try
    {
        $Rp = "HKCU:\SOFTWARE\Classes\AppUserModelId\$ToastAppId"
        if (-not (Test-Path $Rp)) { New-Item $Rp -Force | Out-Null }
        Set-ItemProperty $Rp -Name "DisplayName"        -Value $ToastAppDisplayName -Force -ErrorAction SilentlyContinue
        Set-ItemProperty $Rp -Name "ShowInActionCenter" -Value 1 -Type DWord       -Force -ErrorAction SilentlyContinue

        $null = [Windows.UI.Notifications.ToastNotificationManager, Windows.UI.Notifications, ContentType = WindowsRuntime]
        $null = [Windows.Data.Xml.Dom.XmlDocument, Windows.Data.Xml.Dom, ContentType = WindowsRuntime]

        $Xml = '<toast duration="long"><visual><binding template="ToastGeneric">' +
               '<image placement="appLogoOverride" src="https://s3.us-east-1.wasabisys.com/i3-blob-storage/Installers/i3_CharmOnly_400x300.png" hint-crop="none"/>' +
               "<text>$([Security.SecurityElement]::Escape($Title))</text>" +
               "<text>$([Security.SecurityElement]::Escape($Body))</text>" +
               '<text placement="attribution">Business Solutions</text>' +
               '</binding></visual><audio src="ms-winsoundevent:Notification.Reminder"/></toast>'

        $XmlDoc = [Windows.Data.Xml.Dom.XmlDocument]::new()
        $XmlDoc.LoadXml($Xml)
        $Toast = [Windows.UI.Notifications.ToastNotification]::new($XmlDoc)
        [Windows.UI.Notifications.ToastNotificationManager]::CreateToastNotifier($ToastAppId).Show($Toast)
        Write-Log ("Toast ({0}) shown." -f $Suffix) "SUCCESS"
        Start-Sleep -Seconds 3
    }
    catch { Write-Log ("Send-UserToast failed: {0}" -f $_.Exception.Message) "WARN" }
}

function Remove-Infrastructure
{
    Write-Log "Removing infrastructure..." "INFO"

    foreach ($F in @($ManifestPath, $MarkerPath, $ProtocolHandlerPath, $ToastScriptPath, $VBSLauncherPath, $ToastConfigPath))
    {
        if (Test-Path $F) { Remove-Item $F -Force -ErrorAction SilentlyContinue; Write-Log ("  Removed: {0}" -f (Split-Path $F -Leaf)) "INFO" }
    }

    foreach ($T in @($InstallTaskName, $BootTaskName, $ToastTaskName))
    {
        if (Get-ScheduledTask -TaskName $T -ErrorAction SilentlyContinue)
        {
            Unregister-ScheduledTask -TaskName $T -Confirm:$false -ErrorAction SilentlyContinue
            Write-Log ("  Removed task: {0}" -f $T) "INFO"
        }
    }

    # Remove GPO shutdown script registry keys (both hives)
    try
    {
        foreach ($Key in @($GPOShutdownKey, $GPOStateKey))
        {
            if (Test-Path $Key)
            {
                Remove-Item -Path $Key -Recurse -Force -ErrorAction Stop
                Write-Log ("  Removed GPO key: {0}" -f $Key) "INFO"
            }
        }
    }
    catch { Write-Log ("  GPO key removal failed: {0}" -f $_.Exception.Message) "WARN" }

    # Clean the Shutdown section from scripts.ini
    try
    {
        $ShutdownINI = "$env:SystemRoot\System32\GroupPolicy\Machine\Scripts\scripts.ini"
        if (Test-Path $ShutdownINI)
        {
            $Content = Get-Content $ShutdownINI -Raw -ErrorAction SilentlyContinue
            if ($Content -match '\[Shutdown\]')
            {
                $Content = $Content -replace '(?s)\[Shutdown\][^\[]*', ''
                $Content.Trim() | Set-Content -Path $ShutdownINI -Encoding Unicode -Force
                Write-Log "  Removed [Shutdown] section from scripts.ini." "INFO"
            }
        }
    }
    catch { Write-Log ("  scripts.ini cleanup failed: {0}" -f $_.Exception.Message) "WARN" }

    $Rp = "HKLM:\SOFTWARE\Classes\$ProtocolName"
    if (Test-Path $Rp) { Remove-Item $Rp -Recurse -Force -ErrorAction SilentlyContinue; Write-Log "  Removed protocol registry." "INFO" }
    if ($SelfPath -and (Test-Path $SelfPath)) { Remove-Item $SelfPath -Force -ErrorAction SilentlyContinue; Write-Log "  Removed self." "INFO" }

    Write-Log "Infrastructure removed." "INFO"
}

# ============================================================
# MAIN
# ============================================================
$ComObjects       = [Collections.Generic.List[object]]::new()
$InternalExitCode = $INTERNAL_SUCCESS
$InstallSuccess   = 0
$InstallFail      = 0
$AlreadyInstalled = 0
$RebootCount      = 0
$Status           = "Unknown"

try
{
    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1} | Mode: {2}" -f $ScriptName, $ScriptVersion, $ModeLabel) "INFO"
    Write-Log ("Computer: {0} | PID: {1}" -f $env:COMPUTERNAME, $PID) "INFO"
    Write-Log ("User: {0}" -f [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    if ($ShutdownMode) { Write-Log "ShutdownMode: running as GPO shutdown script. OS will wait for completion." "INFO" }
    Write-Log "============================================================" "INFO"

    if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator))
    {
        $InternalExitCode = $INTERNAL_NOT_ADMIN
        throw "Not running as administrator."
    }

    Write-Log "Admin check passed." "INFO"

    if (-not (New-LockFile))
    {
        $InternalExitCode = $INTERNAL_ALREADY_RUNNING
        throw "Already running (lock held)."
    }

    if (-not $ShutdownMode) { Stop-ToastTask }

    if (Test-Path $ProtocolLogPath)
    {
        Write-Log "Protocol log found." "INFO"
        try
        {
            $ProtoLines = @(Get-Content $ProtocolLogPath -Tail 10 -ErrorAction Stop)
            Remove-Item $ProtocolLogPath -Force -ErrorAction SilentlyContinue
            foreach ($PLine in $ProtoLines) { Write-Log ("  proto: {0}" -f $PLine) "INFO" }
        }
        catch { }
    }

    # Follow-up restart path
    if (-not (Test-Path $ManifestPath))
    {
        if ($UserInitiated -and (Test-Path $MarkerPath))
        {
            try
            {
                $Mk = Get-Content $MarkerPath -Raw -ErrorAction Stop | ConvertFrom-Json
                if ($Mk.Status -eq "RebootPendingAfterInstall")
                {
                    Write-Log "Follow-up restart path." "INFO"
                    Remove-Infrastructure
                    Send-UserToast -Title "Driver Updates" -Body "Restarting in $RestartDelaySec seconds to finish driver updates. Please save your work." -Suffix "PreRestart"
                    & shutdown.exe /r /t $RestartDelaySec /c "Completing driver updates." /d p:2:17
                    Write-Log ("Restart scheduled ({0} sec)." -f $RestartDelaySec) "SUCCESS"
                    Remove-LockFile
                    [Environment]::Exit($INTERNAL_SUCCESS)
                }
            }
            catch { Write-Log ("Follow-up restart check failed: {0}" -f $_.Exception.Message) "WARN" }
        }
        $InternalExitCode = $INTERNAL_NO_MANIFEST
        throw "No manifest found."
    }

    $Manifest    = Get-Content $ManifestPath -Raw -ErrorAction Stop | ConvertFrom-Json
    $ManifestIds = @{}
    foreach ($E in $Manifest.Updates) { $ManifestIds[$E.UpdateID] = $E }
    Write-Log ("Manifest: {0} update(s) from {1}" -f $Manifest.Updates.Count, $Manifest.CreatedAt) "INFO"

    if (-not (Get-Service wuauserv -ErrorAction SilentlyContinue | Where-Object { $_.Status -eq "Running" }))
    {
        Write-Log "Starting wuauserv..." "INFO"
        Start-Service wuauserv -ErrorAction SilentlyContinue
        Start-Sleep -Seconds 5
    }

    if (-not (Get-Service wuauserv -ErrorAction SilentlyContinue | Where-Object { $_.Status -eq "Running" }))
    {
        $InternalExitCode = $INTERNAL_WU_UNAVAILABLE
        throw "Windows Update service is not running."
    }

    Write-Log "Creating WU session..." "INFO"
    $Session  = New-Object -ComObject Microsoft.Update.Session
    $Searcher = $Session.CreateUpdateSearcher()
    $ComObjects.Add($Session)
    $ComObjects.Add($Searcher)

    $SearchResult     = $Searcher.Search("IsInstalled=0 and Type='Driver'")
    $UpdatesToInstall = New-Object -ComObject Microsoft.Update.UpdateColl
    $ComObjects.Add($UpdatesToInstall)

    Write-Log ("WU search: {0} result(s)." -f $SearchResult.Updates.Count) "INFO"

    for ($I = 0; $I -lt $SearchResult.Updates.Count; $I++)
    {
        $U = $SearchResult.Updates.Item($I)
        if (-not $ManifestIds.ContainsKey($U.Identity.UpdateID)) { continue }

        if ($U.IsDownloaded)
        {
            [void]$UpdatesToInstall.Add($U)
            Write-Log ("  Matched (downloaded): {0}" -f $U.Title) "INFO"
        }
        else
        {
            # GPO shutdown scripts have ample time — re-downloads are fine
            Write-Log ("  Re-downloading: {0}" -f $U.Title) "WARN"
            if (-not $U.EulaAccepted) { $U.AcceptEula() }
            $RC = New-Object -ComObject Microsoft.Update.UpdateColl
            [void]$RC.Add($U)
            $RD = $Session.CreateUpdateDownloader()
            $RD.Updates = $RC
            $RR = $RD.Download()
            [Runtime.InteropServices.Marshal]::ReleaseComObject($RD) | Out-Null
            [Runtime.InteropServices.Marshal]::ReleaseComObject($RC) | Out-Null

            if ($RR.GetUpdateResult(0).ResultCode -eq 2)
            {
                [void]$UpdatesToInstall.Add($U)
                Write-Log "  Re-download succeeded." "SUCCESS"
            }
            else
            {
                $InstallFail++
                Write-Log ("  Re-download FAILED: {0}" -f $U.Title) "ERROR"
            }
        }

        $ManifestIds.Remove($U.Identity.UpdateID)
    }

    foreach ($K in $ManifestIds.Keys)
    {
        $AlreadyInstalled++
        Write-Log ("  Already installed: {0}" -f $ManifestIds[$K].Title) "SUCCESS"
    }

    if ($UpdatesToInstall.Count -eq 0)
    {
        if ($AlreadyInstalled -gt 0 -and $InstallFail -eq 0)
        {
            $Status = "AlreadyComplete"
            Write-Log "All updates already installed." "SUCCESS"
            Remove-Infrastructure
        }
        else
        {
            $Status           = "NoMatch"
            $InternalExitCode = $INTERNAL_NO_MATCHING
        }
        throw "Nothing to install."
    }

    # WU busy: in ShutdownMode use a short retry (OS waits for us now).
    # In normal modes use the full retry cycle.
    if (-not (Wait-WUReady -MaxRetries $WUBusyRetryCount -DelaySeconds $WUBusyRetryDelaySec))
    {
        $Status           = "WUBusy"
        $InternalExitCode = $INTERNAL_WU_BUSY
        throw "Windows Update stayed busy."
    }

    Write-Log ("Installing {0} update(s)..." -f $UpdatesToInstall.Count) "INFO"

    $Installer                    = $Session.CreateUpdateInstaller()
    $Installer.Updates            = $UpdatesToInstall
    $Installer.AllowSourcePrompts = $false
    $ComObjects.Add($Installer)
    try { $Installer.ForceQuiet = $true } catch { }

    $T0            = Get-Date
    $InstallResult = $Installer.Install()
    $Duration      = (Get-Date) - $T0

    Write-Log ("Install done in {0}s - {1}" -f [math]::Round($Duration.TotalSeconds), (Get-WUResultText -Code $InstallResult.ResultCode)) "INFO"

    $Results = [Collections.Generic.List[PSCustomObject]]::new()

    for ($I = 0; $I -lt $UpdatesToInstall.Count; $I++)
    {
        $U  = $UpdatesToInstall.Item($I)
        $UR = $InstallResult.GetUpdateResult($I)
        $RB = $UR.RebootRequired

        if ($UR.ResultCode -in @(2, 3))
        {
            $InstallSuccess++
            if ($RB) { $RebootCount++ }
            Write-Log ("  INSTALLED ({0}): {1}" -f $(if ($RB) { 'reboot-pending' } else { 'no-reboot' }), $U.Title) "SUCCESS"
        }
        else
        {
            $InstallFail++
            Write-Log ("  FAILED: {0} - 0x{1}" -f $U.Title, $UR.HResult.ToString('X8')) "ERROR"
        }

        $Results.Add([PSCustomObject]@{
            Title          = $U.Title
            Result         = Get-WUResultText -Code $UR.ResultCode
            RebootRequired = $RB
            HResult        = "0x$($UR.HResult.ToString('X8'))"
        })
    }

    $PR              = Test-PendingReboot
    $EffectiveReboot = $InstallResult.RebootRequired -or $PR.Pending

    Write-Log ("SUMMARY | Installed: {0} | Already: {1} | Failed: {2} | RebootPending: {3}" -f $InstallSuccess, $AlreadyInstalled, $InstallFail, $RebootCount) "INFO"
    Write-Log ("EffectiveReboot: {0} (reasons: {1})" -f $EffectiveReboot, ($PR.Reasons -join ', ')) "INFO"

    if ($InstallFail -gt 0 -and $InstallSuccess -eq 0) { $Status = "Failed";  $InternalExitCode = $INTERNAL_TOTAL_FAIL }
    elseif ($InstallFail -gt 0)                        { $Status = "Partial"; $InternalExitCode = $INTERNAL_PARTIAL }
    else                                               { $Status = "Success"; $InternalExitCode = $INTERNAL_SUCCESS }

    Write-RunSummary @{
        Script = $ScriptName; Version = $ScriptVersion; Mode = $ModeLabel; Status = $Status
        Installed = $InstallSuccess; Already = $AlreadyInstalled; Failed = $InstallFail
        RebootPending = $RebootCount; RebootRequired = $EffectiveReboot
        DurSec = [math]::Round($Duration.TotalSeconds); Results = @($Results)
        ExitCode = $InternalExitCode; Timestamp = (Get-Date).ToString("o")
    }

    if ($InstallSuccess -gt 0)
    {
        if ($ShutdownMode)
        {
            # --------------------------------------------------------
            # ShutdownMode post-install
            # OS is already shutting down — do NOT schedule another restart.
            # --------------------------------------------------------
            Write-Log "ShutdownMode: install completed during shutdown." "SUCCESS"

            if ($InstallFail -eq 0)
            {
                Write-Log "All updates installed cleanly. Removing infrastructure." "SUCCESS"
                Remove-Infrastructure
            }
            else
            {
                # Partial: prune the manifest so the boot task only retries failures
                Write-Log ("Partial shutdown install ({0} failed). Pruning manifest for boot task." -f $InstallFail) "WARN"
                try
                {
                    $SuccessTitles    = $Results | Where-Object { $_.Result -in @("Succeeded", "SucceededWithErrors") } | Select-Object -ExpandProperty Title
                    $RemainingUpdates = @($Manifest.Updates | Where-Object { $_.Title -notin $SuccessTitles })

                    if ($RemainingUpdates.Count -gt 0)
                    {
                        @{
                            CreatedAt    = $Manifest.CreatedAt
                            ComputerName = $env:COMPUTERNAME
                            CreatedBy    = $Manifest.CreatedBy
                            UpdateCount  = $RemainingUpdates.Count
                            Updates      = $RemainingUpdates
                        } | ConvertTo-Json -Depth 10 | Out-File -FilePath $ManifestPath -Encoding UTF8 -Force

                        Write-Log ("Manifest pruned: {0} update(s) remain for boot task." -f $RemainingUpdates.Count) "INFO"
                    }
                    else
                    {
                        Write-Log "All updates accounted for. Removing infrastructure." "SUCCESS"
                        Remove-Infrastructure
                    }
                }
                catch { Write-Log ("Manifest prune failed: {0}. Boot task will re-attempt all." -f $_.Exception.Message) "WARN" }
            }
        }
        elseif ($UserInitiated)
        {
            Write-Log "UserInitiated: cleanup and restart." "INFO"
            Remove-Infrastructure
            Send-UserToast -Title "Driver Updates" -Body "$InstallSuccess driver update(s) installed. Restarting in $RestartDelaySec seconds. Please save your work." -Suffix "PreRestart"
            & shutdown.exe /r /t $RestartDelaySec /c "$InstallSuccess driver update(s) installed." /d p:2:17
            Write-Log ("Restart scheduled ({0} sec)." -f $RestartDelaySec) "SUCCESS"
        }
        else
        {
            # AtStartup
            Write-Log "AtStartup: evaluating reboot." "INFO"

            if ($EffectiveReboot)
            {
                Write-Log ("Reboot required for {0} update(s)." -f $RebootCount) "WARN"

                @{ Status = "RebootPendingAfterInstall"; InstalledThisRun = $InstallSuccess; StillNeedReboot = $RebootCount; ComputerName = $env:COMPUTERNAME; UpdatedAt = (Get-Date).ToString("o") } |
                    ConvertTo-Json -Depth 10 | Out-File $MarkerPath -Encoding UTF8 -Force

                if (Test-Path $ManifestPath) { Remove-Item $ManifestPath -Force -ErrorAction SilentlyContinue; Write-Log "Manifest cleared." "INFO" }

                try { Start-ScheduledTask -TaskName $ToastTaskName -ErrorAction Stop; Write-Log "Toast kicked." "INFO" }
                catch { Write-Log ("Toast kick failed: {0}" -f $_.Exception.Message) "WARN" }
            }
            else
            {
                Write-Log "No reboot required. Cleaning up." "SUCCESS"
                Remove-Infrastructure
                Send-UserToast -Title "Driver Updates" -Body "$InstallSuccess driver update(s) installed. No restart needed." -Suffix "Complete"
            }
        }
    }
    elseif ($AlreadyInstalled -gt 0 -and $InstallFail -eq 0)
    {
        Write-Log "All already installed. Cleaning up." "SUCCESS"
        Remove-Infrastructure
    }
    else
    {
        Write-Log "Install failed or no match. Retaining infrastructure." "WARN"
    }
}
catch
{
    Write-Log ("ERROR: {0}" -f $_.Exception.Message) "ERROR"
    if ($_.ScriptStackTrace) { Write-Log ("Stack: {0}" -f $_.ScriptStackTrace) "ERROR" }
    if ($InternalExitCode -eq $INTERNAL_SUCCESS) { $InternalExitCode = $INTERNAL_CRITICAL }
    if ($Status -eq "Unknown") { $Status = "CriticalFailure" }
    Write-RunSummary @{ Script = $ScriptName; Version = $ScriptVersion; Status = $Status; Error = $_.Exception.Message; ExitCode = $InternalExitCode; Timestamp = (Get-Date).ToString("o") }
}
finally
{
    if ($ComObjects.Count -gt 0) { Clear-ComObjects -Objects $ComObjects }
    Remove-LockFile
    Write-Log ("Exit: {0}" -f $InternalExitCode) "INFO"
    [Environment]::Exit($InternalExitCode)
}
'@

    Set-Content -Path $InstallerScriptPath -Value $Content -Encoding UTF8 -Force
    $FileSize = (Get-Item -Path $InstallerScriptPath).Length
    Write-Log ("Installer script written: {0} ({1} bytes, v3.5.6 embedded)" -f (Split-Path $InstallerScriptPath -Leaf), $FileSize) "SUCCESS"
}

function Write-ToastScript
{
    $Content = @'
<#
.SYNOPSIS
    Shows an adaptive Windows toast notification for i3 driver updates.

.AUTHOR
    Ken Kruis

.VERSION
    1.3.0
#>

[CmdletBinding()]
param
(
    [string]$BasePath          = "C:\ProgramData\i3",
    [int]$LogRetentionDays     = 30,
    [switch]$EnableWpfFallback = $true,
    [switch]$Silent
)

$ScriptName    = "Show-DriverUpdateToast"
$ScriptVersion = "1.3.0"
$RunStamp      = Get-Date -Format "yyyyMMdd_HHmmss"

$LogPath       = Join-Path $BasePath "logs"
$ConfigPath    = Join-Path $BasePath "DriverUpdateToast.config.json"
$ManifestPath  = Join-Path $BasePath "DriverUpdateManifest.json"
$MarkerPath    = Join-Path $BasePath "DriverUpdate_RebootRequired.marker.json"
$StatusPath    = Join-Path $BasePath "DriverUpdateToast.status.json"
$HeartbeatPath = Join-Path $BasePath "DriverUpdateToast.started.txt"
$LogFile       = Join-Path $LogPath "${ScriptName}_${RunStamp}.log"
$ProtocolName  = "i3-drivers"

$ToastAppId          = "i3ITManagement.DriverUpdate"
$ToastAppDisplayName = "Business Solutions"

$Caption        = "i3 Updates Available"
$Mode           = $null
$BodyText       = ""
$PrimaryBtnText = ""
$UpdateCount    = 0

$Status = [ordered]@{
    ScriptName             = $ScriptName;    ScriptVersion          = $ScriptVersion
    ComputerName           = $env:COMPUTERNAME
    UserName               = [Security.Principal.WindowsIdentity]::GetCurrent().Name
    StartedAt              = (Get-Date).ToString("o"); CompletedAt = $null
    Caption                = $Caption;       Mode                   = $null
    ManifestFound          = $false;         MarkerFound            = $false
    ManifestUpdateCount    = 0;              AppIdRegistered        = $false
    ToastAttempted         = $false;         ToastShowCallSucceeded = $false
    WpfFallbackAttempted   = $false;         WpfFallbackShown       = $false
    ActionableStateFound   = $false;         ExitReason             = $null
    Error                  = $null
}

function Write-Log
{
    param ([string]$Message, [string]$Level = "INFO")
    $Line = "{0} [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level.ToUpper(), $Message
    if (-not $Silent) { Write-Host $Line }
    try
    {
        if (-not (Test-Path -Path $LogPath)) { New-Item -Path $LogPath -ItemType Directory -Force | Out-Null }
        Add-Content -Path $LogFile -Value $Line -ErrorAction Stop
    }
    catch { }
}

function Write-Status
{
    try { $Status.CompletedAt = (Get-Date).ToString("o"); $Status | ConvertTo-Json -Depth 10 | Out-File -FilePath $StatusPath -Encoding UTF8 -Force }
    catch { }
}

function Write-Heartbeat
{
    try
    {
        "Started: $(Get-Date -Format 'o')`nScript: $ScriptName v$ScriptVersion`nUser: $($Status.UserName)`nComputer: $($Status.ComputerName)" |
            Set-Content -Path $HeartbeatPath -Encoding UTF8 -Force
    }
    catch { }
}

function Remove-OldLogs
{
    try
    {
        if (-not (Test-Path -Path $LogPath)) { return }
        $Cutoff = (Get-Date).AddDays(-$LogRetentionDays)
        Get-ChildItem -Path $LogPath -File -ErrorAction SilentlyContinue |
            Where-Object { $_.LastWriteTime -lt $Cutoff } |
            ForEach-Object { Remove-Item -Path $_.FullName -Force -ErrorAction SilentlyContinue }
    }
    catch { }
}

function Set-ExitState
{
    param ([string]$Reason, [string]$ErrorMessage = $null)
    $Status.ExitReason = $Reason
    if ($ErrorMessage) { $Status.Error = $ErrorMessage }
    Write-Status
}

function Register-ToastAppId
{
    param ([string]$AppId, [string]$DisplayName)
    try
    {
        $HkcuPath = "HKCU:\SOFTWARE\Classes\AppUserModelId\$AppId"
        if (-not (Test-Path $HkcuPath)) { New-Item $HkcuPath -Force | Out-Null }
        Set-ItemProperty $HkcuPath -Name "DisplayName"           -Value $DisplayName -Force
        Set-ItemProperty $HkcuPath -Name "ShowInSettings"        -Value 1 -Type DWord -Force
        Set-ItemProperty $HkcuPath -Name "ShowInActionCenter"    -Value 1 -Type DWord -Force
        Set-ItemProperty $HkcuPath -Name "AllowContentAboveLock" -Value 0 -Type DWord -Force

        try
        {
            $HklmPath = "HKLM:\SOFTWARE\Classes\AppUserModelId\$AppId"
            if (-not (Test-Path $HklmPath)) { New-Item $HklmPath -Force | Out-Null }
            Set-ItemProperty $HklmPath -Name "DisplayName"        -Value $DisplayName -Force
            Set-ItemProperty $HklmPath -Name "ShowInSettings"     -Value 1 -Type DWord -Force
            Set-ItemProperty $HklmPath -Name "ShowInActionCenter" -Value 1 -Type DWord -Force
        }
        catch { Write-Log ("HKLM AppId write skipped: {0}" -f $_.Exception.Message) "INFO" }

        $NotifPath = "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Notifications\Settings\$AppId"
        if (-not (Test-Path $NotifPath)) { New-Item $NotifPath -Force | Out-Null }
        $Existing = Get-ItemProperty $NotifPath -Name "Enabled" -ErrorAction SilentlyContinue
        if ($null -eq $Existing -or $Existing.Enabled -ne 1) { Set-ItemProperty $NotifPath -Name "Enabled" -Value 1 -Type DWord -Force }

        Write-Log ("AppId registered: {0} ({1})" -f $AppId, $DisplayName) "SUCCESS"
        return $true
    }
    catch { Write-Log ("AppId registration failed: {0}" -f $_.Exception.Message) "WARN"; return $false }
}

function Invoke-DriverInstallProtocol
{
    try { Start-Process -FilePath "${ProtocolName}://install" -ErrorAction Stop | Out-Null; return $true }
    catch { Write-Log ("Protocol launch failed: {0}" -f $_.Exception.Message) "ERROR"; return $false }
}

function Show-WpfFallback
{
    param ([string]$WindowTitle, [string]$MessageText, [string]$ButtonText)
    $Status.WpfFallbackAttempted = $true
    Write-Log "Attempting WPF fallback popup." "WARN"
    try
    {
        Add-Type -AssemblyName PresentationFramework -ErrorAction Stop
        Add-Type -AssemblyName PresentationCore -ErrorAction Stop
        Add-Type -AssemblyName WindowsBase -ErrorAction Stop

        $Xaml = @"
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="$([Security.SecurityElement]::Escape($WindowTitle))"
        Height="240" Width="460" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Topmost="True" ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="$([Security.SecurityElement]::Escape($WindowTitle))"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,12" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="1" Text="$([Security.SecurityElement]::Escape($MessageText))"
                   FontSize="14" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Name="LaterButton" Width="110" Height="34" Margin="0,0,10,0" Content="Later"/>
            <Button Name="ActionButton" Width="180" Height="34" Content="$([Security.SecurityElement]::Escape($ButtonText))"/>
        </StackPanel>
    </Grid>
</Window>
"@
        $Reader = New-Object System.Xml.XmlNodeReader ([xml]$Xaml)
        $Window = [Windows.Markup.XamlReader]::Load($Reader)
        $Window.FindName("LaterButton").Add_Click({ $Window.Tag = "Later"; $Window.Close() })
        $Window.FindName("ActionButton").Add_Click({ $Window.Tag = "Action"; $Window.Close() })
        $null = $Window.ShowDialog()
        $Status.WpfFallbackShown = $true
        Write-Log "WPF fallback displayed and closed." "SUCCESS"
        if ($Window.Tag -eq "Action") { Write-Log "User clicked action." "SUCCESS"; Invoke-DriverInstallProtocol | Out-Null }
        else { Write-Log "User dismissed with Later." "INFO" }
        return $true
    }
    catch { Write-Log ("WPF fallback failed: {0}" -f $_.Exception.Message) "ERROR"; return $false }
}

try
{
    Remove-OldLogs
    foreach ($Dir in @($BasePath, $LogPath)) { if (-not (Test-Path $Dir)) { New-Item $Dir -ItemType Directory -Force | Out-Null } }
    Write-Heartbeat

    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1}" -f $ScriptName, $ScriptVersion) "INFO"
    Write-Log ("Computer: {0} | User: {1}" -f $env:COMPUTERNAME, [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    Write-Log ("AppId: {0}" -f $ToastAppId) "INFO"
    Write-Log "============================================================" "INFO"

    $AppIdOk = Register-ToastAppId -AppId $ToastAppId -DisplayName $ToastAppDisplayName
    $Status.AppIdRegistered = $AppIdOk

    if (Test-Path $ConfigPath)
    {
        try
        {
            $Cfg = Get-Content $ConfigPath -Raw -ErrorAction Stop | ConvertFrom-Json
            if ($Cfg.Caption) { $Caption = [string]$Cfg.Caption; $Status.Caption = $Caption }
            Write-Log ("Config loaded. Caption: '{0}'" -f $Caption) "INFO"
        }
        catch { Write-Log ("Config read failed: {0}" -f $_.Exception.Message) "WARN" }
    }

    if (Test-Path $ManifestPath)
    {
        $Status.ManifestFound = $true
        try
        {
            $Manifest    = Get-Content $ManifestPath -Raw -ErrorAction Stop | ConvertFrom-Json
            $UpdateCount = if ($Manifest.Updates) { @($Manifest.Updates).Count } else { 0 }
            $Status.ManifestUpdateCount = $UpdateCount
            Write-Log ("Manifest update count: {0}" -f $UpdateCount) "INFO"
            if ($UpdateCount -gt 0) { $Mode = "Install"; $BodyText = "$UpdateCount driver/firmware update(s) have been downloaded and are ready to install. Your computer will need to restart."; $PrimaryBtnText = "Install & Restart Now" }
        }
        catch { Write-Log ("Manifest parse failed: {0}" -f $_.Exception.Message) "WARN" }
    }

    if ((-not $Mode) -and (Test-Path $MarkerPath))
    {
        $Status.MarkerFound = $true
        try
        {
            $Marker = Get-Content $MarkerPath -Raw -ErrorAction Stop | ConvertFrom-Json
            if ($Marker.Status -eq "RebootPendingAfterInstall")
            {
                $InstalledValue = if ($Marker.PSObject.Properties.Name -contains "InstalledThisRun" -and $Marker.InstalledThisRun) { [string]$Marker.InstalledThisRun } else { "Some" }
                $PendingValue   = if ($Marker.PSObject.Properties.Name -contains "StillNeedReboot"  -and $Marker.StillNeedReboot)  { [string]$Marker.StillNeedReboot }  else { "some" }
                $Mode = "Restart"; $BodyText = "$InstalledValue driver update(s) were installed, but $PendingValue still need a restart to finish."; $PrimaryBtnText = "Restart Now"
            }
        }
        catch { Write-Log ("Marker parse failed: {0}" -f $_.Exception.Message) "WARN" }
    }

    if (-not $Mode)
    {
        $Status.ActionableStateFound = $false; $Status.Mode = "None"
        Write-Log "No actionable state found. Exiting." "INFO"
        Set-ExitState -Reason "NoActionableState"; exit 0
    }

    $Status.ActionableStateFound = $true; $Status.Mode = $Mode
    Write-Log ("Mode: {0} | Button: {1}" -f $Mode, $PrimaryBtnText) "SUCCESS"

    try
    {
        $Status.ToastAttempted = $true
        $null = [Windows.UI.Notifications.ToastNotificationManager, Windows.UI.Notifications, ContentType = WindowsRuntime]
        $null = [Windows.Data.Xml.Dom.XmlDocument, Windows.Data.Xml.Dom, ContentType = WindowsRuntime]

        $ToastXml = @"
<toast duration="long" scenario="reminder" launch="${ProtocolName}://install">
    <visual>
        <binding template="ToastGeneric">
            <image placement="appLogoOverride" src="https://s3.us-east-1.wasabisys.com/i3-blob-storage/Installers/i3_CharmOnly_400x300.png" hint-crop="none"/>
            <text>$([Security.SecurityElement]::Escape($Caption))</text>
            <text>$([Security.SecurityElement]::Escape($BodyText))</text>
            <text placement="attribution">Business Solutions</text>
        </binding>
    </visual>
    <actions>
        <action content="$([Security.SecurityElement]::Escape($PrimaryBtnText))" activationType="protocol" arguments="${ProtocolName}://install"/>
        <action content="Later" activationType="system" arguments="dismiss"/>
    </actions>
    <audio src="ms-winsoundevent:Notification.Reminder"/>
</toast>
"@
        $XmlDoc = [Windows.Data.Xml.Dom.XmlDocument]::new()
        $XmlDoc.LoadXml($ToastXml)
        $Toast = [Windows.UI.Notifications.ToastNotification]::new($XmlDoc)
        [Windows.UI.Notifications.ToastNotificationManager]::CreateToastNotifier($ToastAppId).Show($Toast)
        $Status.ToastShowCallSucceeded = $true
        Write-Log "Toast Show() returned without error." "SUCCESS"
        Set-ExitState -Reason "ToastShowCallSucceeded"; exit 0
    }
    catch
    {
        $ErrorMessage = $_.Exception.Message
        Write-Log ("Toast display failed: {0}" -f $ErrorMessage) "ERROR"
        if ($EnableWpfFallback)
        {
            $FallbackShown = Show-WpfFallback -WindowTitle $Caption -MessageText $BodyText -ButtonText $PrimaryBtnText
            if ($FallbackShown) { Set-ExitState -Reason "ToastFailed_WpfFallbackShown" -ErrorMessage $ErrorMessage; exit 0 }
        }
        Set-ExitState -Reason "ToastFailed_NoFallbackShown" -ErrorMessage $ErrorMessage; exit 0
    }
}
catch
{
    Write-Log ("Unhandled failure: {0}" -f $_.Exception.Message) "ERROR"
    Set-ExitState -Reason "UnhandledFailure" -ErrorMessage $_.Exception.Message; exit 0
}
'@

    Set-Content -Path $ToastScriptPath -Value $Content -Encoding UTF8 -Force
    $FileSize = (Get-Item -Path $ToastScriptPath).Length
    Write-Log ("Toast script written: {0} ({1} bytes, v1.3.0 embedded)" -f (Split-Path $ToastScriptPath -Leaf), $FileSize) "SUCCESS"
}

# ============================================================
# INFRASTRUCTURE
# ============================================================
function Register-EventLogSource
{
    try
    {
        if (-not [Diagnostics.EventLog]::SourceExists($EventLogSource)) { [Diagnostics.EventLog]::CreateEventSource($EventLogSource, $EventLogName) }
        return $true
    }
    catch { Write-Log ("EventLog source failed: {0}" -f $_.Exception.Message) "ERROR"; return $false }
}

function Register-ProtocolRegistry
{
    try
    {
        $RegistryPath = "HKLM:\SOFTWARE\Classes\$ProtocolName"
        New-Item -Path $RegistryPath -Force | Out-Null
        Set-ItemProperty -Path $RegistryPath -Name "(Default)"    -Value "URL:i3 Driver Update Protocol"
        Set-ItemProperty -Path $RegistryPath -Name "URL Protocol" -Value ""
        New-Item -Path "$RegistryPath\shell\open\command" -Force | Out-Null
        Set-ItemProperty -Path "$RegistryPath\shell\open\command" -Name "(Default)" -Value "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$ProtocolHandlerPath`" `"%1`""
        return $true
    }
    catch { Write-Log ("Protocol registry failed: {0}" -f $_.Exception.Message) "ERROR"; return $false }
}

function Register-InstallTask
{
    try
    {
        $ExistingTask = Get-ScheduledTask -TaskName $InstallTaskName -ErrorAction SilentlyContinue
        if ($ExistingTask) { Unregister-ScheduledTask -TaskName $InstallTaskName -Confirm:$false -ErrorAction Stop }

        $Action    = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$InstallerScriptPath`" -UserInitiated"
        $Principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest
        $Settings  = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable -MultipleInstances Queue -ExecutionTimeLimit (New-TimeSpan -Hours 2)

        Register-ScheduledTask -TaskName $InstallTaskName -Action $Action -Principal $Principal -Settings $Settings -Force | Out-Null

        $Verify = Get-ScheduledTask -TaskName $InstallTaskName -ErrorAction SilentlyContinue
        if (-not $Verify) { Write-Log "Install task not found after registration." "ERROR"; return $false }

        Write-Log ("Install task: {0} (SYSTEM, Queue, -UserInitiated) -- VERIFIED" -f $InstallTaskName) "SUCCESS"
        return $true
    }
    catch { Write-Log ("Install task failed: {0}" -f $_.Exception.Message) "ERROR"; return $false }
}

function Register-BootFallbackTask
{
    try
    {
        $ExistingTask = Get-ScheduledTask -TaskName $BootTaskName -ErrorAction SilentlyContinue
        if ($ExistingTask) { Unregister-ScheduledTask -TaskName $BootTaskName -Confirm:$false -ErrorAction Stop }

        $Action    = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$InstallerScriptPath`""
        $Trigger   = New-ScheduledTaskTrigger -AtStartup
        $Principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest
        $Settings  = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -MultipleInstances IgnoreNew -StartWhenAvailable

        Register-ScheduledTask -TaskName $BootTaskName -Action $Action -Trigger $Trigger -Principal $Principal -Settings $Settings -Force | Out-Null
        Write-Log ("Boot fallback task: {0} (AtStartup, SYSTEM)" -f $BootTaskName) "SUCCESS"
        return $true
    }
    catch { Write-Log ("Boot fallback task failed: {0}" -f $_.Exception.Message) "ERROR"; return $false }
}

function Register-ShutdownScript
{
    # Registers the installer as a GPO shutdown script via registry.
    # Windows reads HKLM\...\Group Policy\Scripts\Shutdown at shutdown time
    # and executes all registered scripts in the dedicated shutdown script phase.
    # The OS shows "Please do not power off your computer" and waits up to
    # MaxShutdownScriptTimeout (default 600s / 10 min) before force-killing.
    #
    # Two registry hives are written — both are required:
    #   Scripts\Shutdown  : the policy definition (what to run)
    #   State\...\Shutdown: the effective state cache (what userenv.dll actually reads)
    #
    # We use index "0" for our GPO slot. Real domain GPOs use GUIDs as sub-key
    # names so there is no collision risk. Local GPO scripts use numeric indexes.
    # If the machine has existing local shutdown scripts at index 0 this will
    # co-exist — we write to sub-index "0" within our slot.
    try
    {
        # ---- Scripts hive (policy definition) ----
        foreach ($Key in @($GPOShutdownKey, $GPOScriptKey))
        {
            if (-not (Test-Path $Key)) { New-Item -Path $Key -Force | Out-Null }
        }

        # GPO-level metadata
        Set-ItemProperty -Path $GPOShutdownKey -Name "DisplayName" -Value "Local Group Policy"  -Force
        Set-ItemProperty -Path $GPOShutdownKey -Name "FileSysPath"  -Value "$env:SystemRoot\System32\GroupPolicy\Machine" -Force
        Set-ItemProperty -Path $GPOShutdownKey -Name "GPO-ID"       -Value "LocalGPO"           -Force
        Set-ItemProperty -Path $GPOShutdownKey -Name "GPOName"      -Value "Local Group Policy"  -Force
        Set-ItemProperty -Path $GPOShutdownKey -Name "PSScriptOrder" -Value 1 -Type DWord        -Force
        Set-ItemProperty -Path $GPOShutdownKey -Name "SOM-ID"       -Value "Local"               -Force

        # Script entry
        Set-ItemProperty -Path $GPOScriptKey -Name "Script"     -Value "powershell.exe"          -Force
        Set-ItemProperty -Path $GPOScriptKey -Name "Parameters" -Value "-NoLogo -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$InstallerScriptPath`" -ShutdownMode" -Force
        Set-ItemProperty -Path $GPOScriptKey -Name "IsPowershell" -Value 1 -Type DWord           -Force
        Set-ItemProperty -Path $GPOScriptKey -Name "ExecTime"   -Value 0 -Type QWord             -Force

        # ---- State hive (effective state — what userenv.dll actually reads) ----
        foreach ($Key in @($GPOStateKey, $GPOStateScriptKey))
        {
            if (-not (Test-Path $Key)) { New-Item -Path $Key -Force | Out-Null }
        }

        Set-ItemProperty -Path $GPOStateKey -Name "DisplayName" -Value "Local Group Policy"  -Force
        Set-ItemProperty -Path $GPOStateKey -Name "FileSysPath"  -Value "$env:SystemRoot\System32\GroupPolicy\Machine" -Force
        Set-ItemProperty -Path $GPOStateKey -Name "GPO-ID"       -Value "LocalGPO"           -Force
        Set-ItemProperty -Path $GPOStateKey -Name "GPOName"      -Value "Local Group Policy"  -Force
        Set-ItemProperty -Path $GPOStateKey -Name "PSScriptOrder" -Value 1 -Type DWord        -Force
        Set-ItemProperty -Path $GPOStateKey -Name "SOM-ID"       -Value "Local"               -Force

        Set-ItemProperty -Path $GPOStateScriptKey -Name "Script"     -Value "powershell.exe"  -Force
        Set-ItemProperty -Path $GPOStateScriptKey -Name "Parameters" -Value "-NoLogo -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$InstallerScriptPath`" -ShutdownMode" -Force
        Set-ItemProperty -Path $GPOStateScriptKey -Name "IsPowershell" -Value 1 -Type DWord   -Force
        Set-ItemProperty -Path $GPOStateScriptKey -Name "ExecTime"   -Value 0 -Type QWord     -Force

        # Optional: set MaxShutdownScriptTimeout to 600s (10 min) explicitly
        # so the wait time is defined even if GPO hasn't set it.
        # Located at: HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
        $PolicyKey = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System"
        $Existing  = Get-ItemProperty -Path $PolicyKey -Name "MaxShutdownScriptTimeout" -ErrorAction SilentlyContinue
        if (-not $Existing)
        {
            Set-ItemProperty -Path $PolicyKey -Name "MaxShutdownScriptTimeout" -Value 600 -Type DWord -Force
            Write-Log "MaxShutdownScriptTimeout set to 600s." "INFO"
        }
        else
        {
            Write-Log ("MaxShutdownScriptTimeout already set: {0}s." -f $Existing.MaxShutdownScriptTimeout) "INFO"
        }

        Write-Log ("GPO shutdown script registered: {0} -ShutdownMode" -f $InstallerScriptPath) "SUCCESS"
        Write-Log ("  Scripts key : {0}" -f $GPOScriptKey) "INFO"
        Write-Log ("  State key   : {0}" -f $GPOStateScriptKey) "INFO"
        return $true
    }
    catch
    {
        Write-Log ("GPO shutdown script registration failed: {0}" -f $_.Exception.Message) "ERROR"
        return $false
    }
}

function Register-ToastTask
{
    try
    {
        $ExistingTask = Get-ScheduledTask -TaskName $ToastTaskName -ErrorAction SilentlyContinue
        if ($ExistingTask) { Unregister-ScheduledTask -TaskName $ToastTaskName -Confirm:$false -ErrorAction Stop }

        $User = Get-ActiveConsoleUser

        if (-not $User)
        {
            Write-Log "No interactive user - toast task will fire at next logon." "WARN"
            $Principal = New-ScheduledTaskPrincipal -GroupId "BUILTIN\Users" -RunLevel Limited
        }
        else
        {
            Write-Log ("Toast task for: {0}" -f $User) "INFO"
            $Principal = New-ScheduledTaskPrincipal -UserId $User -LogonType Interactive -RunLevel Limited
        }

        $Action      = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoLogo -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$ToastScriptPath`""
        $RepeatStart = (Get-Date).AddSeconds($SnoozeSeconds)
        $Trigger1    = New-ScheduledTaskTrigger -Once -At $RepeatStart -RepetitionInterval (New-TimeSpan -Seconds $SnoozeSeconds) -RepetitionDuration (New-TimeSpan -Days $NotifyMaxDays)
        $Trigger2    = New-ScheduledTaskTrigger -AtLogOn
        $Settings    = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable -MultipleInstances IgnoreNew -Hidden

        Register-ScheduledTask -TaskName $ToastTaskName -Action @($Action) -Trigger @($Trigger1, $Trigger2) -Principal $Principal -Settings $Settings -Force | Out-Null
        Write-Log ("Toast task: {0} (repeat every {1}h for {2}d + AtLogOn)" -f $ToastTaskName, ($SnoozeSeconds / 3600), $NotifyMaxDays) "SUCCESS"
        return $true
    }
    catch { Write-Log ("Toast task failed: {0}" -f $_.Exception.Message) "WARN"; return $false }
}

# ============================================================
# MAIN
# ============================================================
$ComObjects       = [Collections.Generic.List[object]]::new()
$InternalExitCode = $INTERNAL_SUCCESS
$DownloadedCount  = 0

try
{
    Remove-OldLogs

    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1}" -f $ScriptName, $ScriptVersion) "INFO"
    Write-Log ("Computer: {0} | User: {1}" -f $env:COMPUTERNAME, [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    Write-Log ("Snooze: {0}h | MaxDays: {1} | Companion scripts: EMBEDDED v5.8.5 (no S3 download)" -f $NotifyIntervalHours, $NotifyMaxDays) "INFO"
    Write-Log "============================================================" "INFO"

    $IsAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
    if (-not $IsAdmin) { $InternalExitCode = $INTERNAL_NOT_ADMIN; throw "Not running as administrator." }

    foreach ($Directory in @($BasePath, $LogPath))
    {
        if (-not (Test-Path -Path $Directory)) { New-Item -Path $Directory -ItemType Directory -Force | Out-Null }
    }

    if (-not (New-LockFile))
    {
        $CWExitCode = Get-CWExitCode -Code $INTERNAL_ALREADY_RUNNING
        Write-Output "EXIT: Already running"
        [Environment]::Exit($CWExitCode)
    }

    Remove-LegacyArtifacts

    foreach ($Path in @($ToastStatusPath, $ToastHeartbeatPath, $ProtocolLogPath))
    {
        if (Test-Path -Path $Path) { Remove-Item -Path $Path -Force -ErrorAction SilentlyContinue }
    }

    Write-InstallerScript
    if (-not (Test-ScriptParse -FilePath $InstallerScriptPath)) { $InternalExitCode = $INTERNAL_WRITE_FAILED; throw "Installer script failed parse check." }

    Write-ToastScript
    if (-not (Test-ScriptParse -FilePath $ToastScriptPath)) { $InternalExitCode = $INTERNAL_WRITE_FAILED; throw "Toast script failed parse check." }

    Write-ToastConfig
    Write-ProtocolHandler
    if (-not (Test-ScriptParse -FilePath $ProtocolHandlerPath)) { $InternalExitCode = $INTERNAL_WRITE_FAILED; throw "Protocol handler failed parse check." }

    $WUService = Get-Service -Name wuauserv -ErrorAction SilentlyContinue
    if (-not $WUService) { $InternalExitCode = $INTERNAL_WU_UNAVAILABLE; throw "Windows Update service not found." }
    if ($WUService.Status -ne "Running") { Start-Service -Name wuauserv -ErrorAction SilentlyContinue; Start-Sleep -Seconds 3 }

    $Session  = New-Object -ComObject Microsoft.Update.Session
    $Searcher = $Session.CreateUpdateSearcher()
    $ComObjects.Add($Session)
    $ComObjects.Add($Searcher)

    Write-Log "Scanning: IsInstalled=0 and Type='Driver'" "INFO"
    $SearchResult = $Searcher.Search("IsInstalled=0 and Type='Driver'")
    $UpdateCount  = $SearchResult.Updates.Count

    Write-Log ("Found {0} applicable update(s)." -f $UpdateCount) "INFO"

    if ($UpdateCount -eq 0)
    {
        Write-Log "No updates. System is current." "SUCCESS"

        foreach ($TaskName in @($InstallTaskName, $BootTaskName, $ToastTaskName))
        {
            $Task = Get-ScheduledTask -TaskName $TaskName -ErrorAction SilentlyContinue
            if ($Task) { Unregister-ScheduledTask -TaskName $TaskName -Confirm:$false -ErrorAction SilentlyContinue }
        }

        # Remove GPO shutdown script registry keys if present
        foreach ($RegKey in @($GPOScriptKey, $GPOShutdownKey, $GPOStateScriptKey, $GPOStateKey))
        {
            if (Test-Path $RegKey) { Remove-Item $RegKey -Recurse -Force -ErrorAction SilentlyContinue }
        }

        foreach ($FilePath in @($ManifestPath, $MarkerPath, $ProtocolHandlerPath, $ToastScriptPath, $ToastConfigPath, $ToastStatusPath, $ToastHeartbeatPath, $ProtocolLogPath))
        {
            if (Test-Path -Path $FilePath) { Remove-Item -Path $FilePath -Force -ErrorAction SilentlyContinue }
        }

        $ProtocolRegistryPath = "HKLM:\SOFTWARE\Classes\$ProtocolName"
        if (Test-Path -Path $ProtocolRegistryPath) { Remove-Item -Path $ProtocolRegistryPath -Recurse -Force -ErrorAction SilentlyContinue }

        Write-RunSummary @{ Status = "Success"; Reason = "No updates"; ExitCode = $INTERNAL_NO_UPDATES; Timestamp = (Get-Date).ToString("o") }
        $InternalExitCode = $INTERNAL_NO_UPDATES
        Remove-LockFile
        [Environment]::Exit((Get-CWExitCode -Code $InternalExitCode))
    }

    for ($Index = 0; $Index -lt $UpdateCount; $Index++)
    {
        $Update = $SearchResult.Updates.Item($Index)
        $MB     = [math]::Round(($Update.MaxDownloadSize / 1MB), 2)
        $Info   = "{0} ({1}MB" -f $Update.Title, $MB
        if ($Update.DriverClass)    { $Info += ", $($Update.DriverClass)" }
        if ($Update.DriverProvider) { $Info += " / $($Update.DriverProvider)" }
        $Info += ")"
        Write-Log ("  [{0}/{1}] {2}" -f ($Index + 1), $UpdateCount, $Info) "INFO"
    }

    $UpdatesToDownload = New-Object -ComObject Microsoft.Update.UpdateColl
    $ComObjects.Add($UpdatesToDownload)

    foreach ($Update in $SearchResult.Updates)
    {
        if (-not $Update.EulaAccepted) { $Update.AcceptEula() }
        [void]$UpdatesToDownload.Add($Update)
    }

    $Downloader         = $Session.CreateUpdateDownloader()
    $Downloader.Updates = $UpdatesToDownload
    $ComObjects.Add($Downloader)

    Write-Log ("Downloading {0} update(s) (NO install)..." -f $UpdateCount) "INFO"
    $DownloadStart    = Get-Date
    $DownloadResult   = $Downloader.Download()
    $DownloadDuration = (Get-Date) - $DownloadStart

    Write-Log ("Download done in {0}s -- {1}" -f [math]::Round($DownloadDuration.TotalSeconds), (Get-ResultCodeText -Code $DownloadResult.ResultCode)) "INFO"

    $ManifestUpdates   = [Collections.Generic.List[PSCustomObject]]::new()
    $DownloadFailCount = 0

    for ($Index = 0; $Index -lt $UpdatesToDownload.Count; $Index++)
    {
        $Update       = $UpdatesToDownload.Item($Index)
        $UpdateResult = $DownloadResult.GetUpdateResult($Index)

        if (($UpdateResult.ResultCode -eq 2) -and $Update.IsDownloaded)
        {
            $DownloadedCount++
            Write-Log ("  Downloaded: {0}" -f $Update.Title) "SUCCESS"
            $ManifestUpdates.Add([PSCustomObject]@{
                UpdateID       = $Update.Identity.UpdateID
                RevisionNumber = $Update.Identity.RevisionNumber
                Title          = $Update.Title
                DriverClass    = if ($Update.DriverClass)    { $Update.DriverClass }    else { "" }
                DriverProvider = if ($Update.DriverProvider) { $Update.DriverProvider } else { "" }
                DriverVerDate  = if ($Update.DriverVerDate)  { $Update.DriverVerDate.ToString("yyyy-MM-dd") } else { "" }
                SizeMB         = [math]::Round(($Update.MaxDownloadSize / 1MB), 2)
            })
        }
        else
        {
            $DownloadFailCount++
            Write-Log ("  FAILED: {0}" -f $Update.Title) "ERROR"
        }
    }

    if ($DownloadedCount -eq 0) { $InternalExitCode = $INTERNAL_DOWNLOAD_FAIL; throw "All downloads failed." }

    @{
        CreatedAt    = (Get-Date).ToString("o")
        ComputerName = $env:COMPUTERNAME
        CreatedBy    = "{0} v{1}" -f $ScriptName, $ScriptVersion
        UpdateCount  = $ManifestUpdates.Count
        Updates      = @($ManifestUpdates)
    } | ConvertTo-Json -Depth 10 | Out-File -FilePath $ManifestPath -Encoding UTF8 -Force

    Write-Log ("Manifest: {0} ({1} update(s))" -f $ManifestPath, $ManifestUpdates.Count) "SUCCESS"

    @{
        Status       = "UpdatesReadyForInstall"
        UpdateCount  = $ManifestUpdates.Count
        ComputerName = $env:COMPUTERNAME
        CreatedAt    = (Get-Date).ToString("o")
    } | ConvertTo-Json -Depth 10 | Out-File -FilePath $MarkerPath -Encoding UTF8 -Force

    Write-Log "Setting up infrastructure..." "INFO"

    $EventLogOk     = Register-EventLogSource
    $ProtocolOk     = Register-ProtocolRegistry
    $InstallOk      = Register-InstallTask
    $BootTaskOk     = Register-BootFallbackTask
    $ShutdownOk     = Register-ShutdownScript
    $ToastTaskOk    = Register-ToastTask

    if ((-not $EventLogOk) -or (-not $ProtocolOk) -or (-not $InstallOk))
    {
        Write-Log "Infrastructure registration issue detected." "WARN"
        $InternalExitCode = $INTERNAL_INFRA_FAILED
    }

    if ($ToastTaskOk)
    {
        Start-Sleep -Seconds 2
        try { Start-ScheduledTask -TaskName $ToastTaskName -ErrorAction Stop; Write-Log "Toast task started." "SUCCESS" }
        catch { Write-Log ("Toast task start failed: {0}" -f $_.Exception.Message) "WARN" }
    }

    Write-Log "------------------------------------------------------------" "INFO"
    Write-Log ("Found: {0} | Downloaded: {1} | Failed: {2}" -f $UpdateCount, $DownloadedCount, $DownloadFailCount) "INFO"
    Write-Log ("GPO shutdown script registered: {0}" -f $ShutdownOk) "INFO"
    Write-Log "Boot fallback task (AtStartup): safety net if shutdown install incomplete" "INFO"
    Write-Log "------------------------------------------------------------" "INFO"

    if ($InternalExitCode -eq $INTERNAL_SUCCESS) { Write-Log "SUCCESS -- Updates downloaded and notification workflow started." "SUCCESS" }

    Write-RunSummary @{
        ScriptName          = $ScriptName
        Version             = $ScriptVersion
        ComputerName        = $env:COMPUTERNAME
        Status              = if ($InternalExitCode -eq 0) { "Success" } else { "Partial" }
        UpdatesFound        = $UpdateCount
        Downloaded          = $DownloadedCount
        DownloadFailed      = $DownloadFailCount
        CompanionSource     = "Embedded"
        InstallerVersion    = "3.5.6"
        ToastVersion        = "1.3.0"
        NotifyIntervalHours = $NotifyIntervalHours
        NotifyMaxDays       = $NotifyMaxDays
        Infra               = @{
            Event          = $EventLogOk
            Protocol       = $ProtocolOk
            InstallTask    = $InstallOk
            BootTask       = $BootTaskOk
            ShutdownScript = $ShutdownOk
            ToastTask      = $ToastTaskOk
        }
        DownloadDurationSec = [math]::Round($DownloadDuration.TotalSeconds)
        ExitCode            = $InternalExitCode
        Timestamp           = (Get-Date).ToString("o")
    }
}
catch
{
    Write-Log ("CRITICAL: {0}" -f $_.Exception.Message) "ERROR"
    if ($_.ScriptStackTrace) { Write-Log ("Stack: {0}" -f $_.ScriptStackTrace) "ERROR" }
    if ($InternalExitCode -eq $INTERNAL_SUCCESS) { $InternalExitCode = $INTERNAL_CRITICAL }
    Write-RunSummary @{ Status = "CriticalFailure"; Error = $_.Exception.Message; ExitCode = $InternalExitCode; Timestamp = (Get-Date).ToString("o") }
}
finally
{
    if ($ComObjects.Count -gt 0) { Clear-ComObjects -Objects $ComObjects }
    Remove-LockFile
    $CWExitCode = Get-CWExitCode -Code $InternalExitCode
    Write-Log ("EXIT: DL={0} Internal={1} CW={2}" -f $DownloadedCount, $InternalExitCode, $CWExitCode) "INFO"
    Write-Output ("EXIT: {0} v{1} -- DL={2} Internal={3} CW={4}" -f $ScriptName, $ScriptVersion, $DownloadedCount, $InternalExitCode, $CWExitCode)
    [Environment]::Exit($CWExitCode)
}
