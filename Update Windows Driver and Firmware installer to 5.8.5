}
finally
{
    Write-Log ("Exit: {0}" -f $InternalExit)
    [Environment]::Exit($InternalExit)
}
'@
    Set-Content -Path $ProtocolHandlerPath -Value $Content -Force -Encoding UTF8
    Write-Log "Protocol handler written (PS1 launcher -> Start-ScheduledTask)." "INFO"
}

