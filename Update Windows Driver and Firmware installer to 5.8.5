function Write-InstallerScript
{
    # Install-DriversAndRestart.ps1 v3.5.6
    $Content = @'
<#
.SYNOPSIS
    Installs downloaded driver updates via WU API and restarts.

.DESCRIPTION
    Runs as SYSTEM via scheduled task. Three modes:
    - UserInitiated : Triggered by toast button. Cleans up and restarts.
    - AtStartup     : Boot fallback. Silent install, sets reboot marker if needed.
    - ShutdownMode  : Registered as a GPO shutdown script. Windows waits for this
                      script to complete before proceeding with shutdown (up to the
                      configured GPO timeout, default 600s). Does NOT schedule an
                      additional restart — the OS is already shutting down.
                      If the install fails or is incomplete, the AtStartup boot
                      task catches remaining updates on next boot.

.AUTHOR
    Ken Kruis

.VERSION
    3.5.6

.CHANGELOG
    3.5.6 - ShutdownMode now runs as a GPO shutdown script instead of an Event
            1074 task. Removed MaxInstallSeconds deadline budget — Windows
            natively waits for GPO scripts so no artificial timeout is needed.
            WU-busy handling in ShutdownMode changed from immediate bail to a
            short 3-retry wait (Windows gives us time now). Remove-Infrastructure
            cleans GPO shutdown script registry keys instead of a scheduled task.
    3.5.5 - Added ShutdownMode with deadline budget for Event 1074 task.
    3.5.4 - Send-UserToast skips gracefully when running as SYSTEM.
    3.5.3 - Fixed recursive protocol log echo.
#>

[CmdletBinding()]
param
(
    [switch]$UserInitiated,
    [switch]$ShutdownMode,
    [switch]$Silent
)

$BasePath            = "C:\ProgramData\i3"
$LogPath             = Join-Path $BasePath "logs"
$ManifestPath        = Join-Path $BasePath "DriverUpdateManifest.json"
$MarkerPath          = Join-Path $BasePath "DriverUpdate_RebootRequired.marker.json"
$ToastScriptPath     = Join-Path $BasePath "Show-DriverUpdateToast.ps1"
$VBSLauncherPath     = Join-Path $BasePath "Show-DriverUpdateToast.vbs"
$ProtocolHandlerPath = Join-Path $BasePath "Request-DriverInstall.ps1"
$ToastConfigPath     = Join-Path $BasePath "DriverUpdateToast.config.json"
$ProtocolLogPath     = Join-Path $LogPath  "Request-DriverInstall.log"
$ProtocolName        = "i3-drivers"
$InstallTaskName     = "i3_DriverInstallAndRestart"
$BootTaskName        = "i3_DriverInstallAtBoot"
$ToastTaskName       = "i3_DriverUpdateNotify"
$GPOShutdownKey      = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Group Policy\Scripts\Shutdown\0"
$GPOStateKey         = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Group Policy\State\Machine\Scripts\Shutdown\0"
$RestartDelaySec     = 60
$WUBusyRetryCount    = 3
$WUBusyRetryDelaySec = 20
$ToastAppId          = "i3ITManagement.DriverUpdate"
$ToastAppDisplayName = "Business Solutions"

$INTERNAL_SUCCESS         = 0
$INTERNAL_NO_MANIFEST     = 10
$INTERNAL_ALREADY_RUNNING = 11
$INTERNAL_NOT_ADMIN       = 12
$INTERNAL_WU_UNAVAILABLE  = 13
$INTERNAL_NO_MATCHING     = 14
$INTERNAL_WU_BUSY         = 15
$INTERNAL_PARTIAL         = 20
$INTERNAL_TOTAL_FAIL      = 21
$INTERNAL_CRITICAL        = 99

$ScriptName    = "Install-DriversAndRestart"
$ScriptVersion = "3.5.6"
$RunStamp      = Get-Date -Format "yyyyMMdd_HHmmss"
$LogFile       = Join-Path $LogPath "${ScriptName}_${RunStamp}.log"
$SummaryPath   = Join-Path $LogPath "${ScriptName}_RunSummary_${RunStamp}.json"
$LockFile      = Join-Path $BasePath "${ScriptName}.lock"
$StartedMarker = Join-Path $LogPath "${ScriptName}_${RunStamp}.started"
$SelfPath      = $null

try   { $SelfPath = $MyInvocation.MyCommand.Path } catch { }

# Determine mode label once
$ModeLabel = if ($ShutdownMode) { "ShutdownMode" } elseif ($UserInitiated) { "UserInitiated" } else { "AtStartup" }

try
{
    if (-not (Test-Path $LogPath)) { New-Item $LogPath -ItemType Directory -Force | Out-Null }
    "Started: $(Get-Date -Format 'o') | PID: $PID | User: $([Security.Principal.WindowsIdentity]::GetCurrent().Name) | Mode: $ModeLabel | v$ScriptVersion" |
        Out-File -FilePath $StartedMarker -Encoding UTF8 -Force
}
catch { }

function Write-Log
{
    param ([string]$Message, [string]$Level = "INFO")
    $Line = "{0} [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level.ToUpper(), $Message
    if (-not $Silent)
    {
        Write-Host $Line
        if ($Level -in @("SUCCESS", "ERROR", "WARN")) { Write-Output $Line }
    }
    try
    {
        if (-not (Test-Path $LogPath)) { New-Item $LogPath -ItemType Directory -Force | Out-Null }
        Add-Content -Path $LogFile -Value $Line -ErrorAction Stop
    }
    catch { }
}

function Write-RunSummary
{
    param ([hashtable]$Data)
