function New-LockFile
{
    try
    {
        $Data   = @{ ScriptName = $ScriptName; PID = $PID; Computer = $env:COMPUTERNAME; CreatedAt = (Get-Date).ToString("o"); Mode = $ModeLabel }
        $Bytes  = [Text.Encoding]::UTF8.GetBytes(($Data | ConvertTo-Json -Depth 5))
        $Stream = [IO.File]::Open($LockFile, [IO.FileMode]::CreateNew, [IO.FileAccess]::Write, [IO.FileShare]::None)
        try { $Stream.Write($Bytes, 0, $Bytes.Length); $Stream.Flush() }
        finally { $Stream.Close(); $Stream.Dispose() }
        return $true
    }
    catch [IO.IOException]
    {
        try
        {
            $Ex = Get-Content $LockFile -Raw -ErrorAction Stop | ConvertFrom-Json
            # Shorter stale threshold in ShutdownMode — can't wait 2 hours
            $StaleHours = if ($ShutdownMode) { 0.167 } else { 2 }
            if (((Get-Date) - [datetime]$Ex.CreatedAt).TotalHours -gt $StaleHours)
            {
                Write-Log "Stale lock. Clearing." "WARN"
                Remove-Item $LockFile -Force -ErrorAction SilentlyContinue
                return (New-LockFile)
            }
            Write-Log ("Lock held by PID {0} (Mode: {1}) since {2}." -f $Ex.PID, $Ex.Mode, $Ex.CreatedAt) "WARN"
        }
        catch { }
        return $false
    }
    catch { return $false }
}

function Remove-LockFile
{
    try { if (Test-Path $LockFile) { Remove-Item $LockFile -Force -ErrorAction SilentlyContinue } }
    catch { }
}

