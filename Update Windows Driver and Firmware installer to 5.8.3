function Write-ProtocolHandler
{
    $Content = @'
[CmdletBinding()]
param
(
    [string]$ProtocolArg
)

$BasePath        = "C:\ProgramData\i3"
$LogPath         = Join-Path $BasePath "logs"
$LogFile         = Join-Path $LogPath "Request-DriverInstall.log"
$TaskName        = "i3_DriverInstallAndRestart"
$ScriptName      = "Request-DriverInstall"
$ScriptVersion   = "1.0.0"
$InternalExit    = 0

function Write-Log
{
    param
    (
        [string]$Message,
        [string]$Level = "INFO"
    )

    $Line = "{0} [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level.ToUpper(), $Message

    try
    {
        if (-not (Test-Path -Path $LogPath))
        {
            New-Item -Path $LogPath -ItemType Directory -Force | Out-Null
        }

        Add-Content -Path $LogFile -Value $Line -ErrorAction Stop
    }
    catch
    {
    }
}

try
{
    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1}" -f $ScriptName, $ScriptVersion) "INFO"
    Write-Log ("User: {0}" -f [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    Write-Log ("ProtocolArg: {0}" -f $ProtocolArg) "INFO"
    Write-Log ("Triggering scheduled task via Start-ScheduledTask: {0}" -f $TaskName) "INFO"

    $Task = Get-ScheduledTask -TaskName $TaskName -ErrorAction Stop
    Start-ScheduledTask -InputObject $Task -ErrorAction Stop

    Write-Log "Task trigger succeeded." "SUCCESS"
    $InternalExit = 0
}
catch
{
    $InternalExit = 1
    Write-Log ("Task trigger FAILED: {0}" -f $_.Exception.Message) "ERROR"
}
finally
{
    Write-Log ("Exit: {0}" -f $InternalExit) "INFO"
    [Environment]::Exit($InternalExit)
}
'@

    Set-Content -Path $ProtocolHandlerPath -Value $Content -Force -Encoding UTF8
    Write-Log "Protocol handler written (PowerShell launcher using Start-ScheduledTask)." "INFO"
}

