function Test-WUBusy
{
    try
    {
        $Installer = New-Object -ComObject Microsoft.Update.Installer
        $Busy = $Installer.IsBusy
        [Runtime.InteropServices.Marshal]::ReleaseComObject($Installer) | Out-Null
        return $Busy
    }
    catch
    {
        return $false
    }
}

function Wait-WUReady
{
    param
    (
        [int]$MaxRetries,
        [int]$DelaySeconds
    )

    for ($Index = 0; $Index -lt $MaxRetries; $Index++)
    {
        if (-not (Test-WUBusy))
        {
            if ($Index -gt 0)
            {
                Write-Log "WU ready after $Index retries." "SUCCESS"
            }

            return $true
        }

        Write-Log ("WU busy ({0}/{1}, waiting {2}s)..." -f ($Index + 1), $MaxRetries, $DelaySeconds) "WARN"
        Start-Sleep -Seconds $DelaySeconds
    }

    Write-Log "WU stayed busy after $MaxRetries retries." "ERROR"
    return $false
}

function Test-PendingReboot
{
    $Pending = $false
    $Reasons = [Collections.Generic.List[string]]::new()

    try
    {
        if (Test-Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending")
        {
            $Pending = $true
            $Reasons.Add("CBS")
        }
    }
    catch
    {
    }

    try
    {
        if (Test-Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired")
        {
            $Pending = $true
            $Reasons.Add("WU")
        }
    }
    catch
    {
    }

    try
    {
        if ($null -ne (Get-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager" -Name PendingFileRenameOperations -ErrorAction SilentlyContinue))
        {
            $Pending = $true
            $Reasons.Add("PFR")
        }
    }
    catch
    {
    }

    return [PSCustomObject]@{
        Pending = $Pending
        Reasons = @($Reasons)
    }
}

function Stop-ToastTask
{
    try
    {
        if (Get-ScheduledTask -TaskName $ToastTaskName -ErrorAction SilentlyContinue)
        {
            Unregister-ScheduledTask -TaskName $ToastTaskName -Confirm:$false -ErrorAction SilentlyContinue
            Write-Log "Toast task removed." "INFO"
        }
    }
    catch
    {
        Write-Log ("Failed to remove toast task: {0}" -f $_.Exception.Message) "WARN"
    }
}

function Send-UserToast
{
    param
    (
        [string]$Title,
        [string]$Body,
        [string]$Suffix = "Msg"
    )

    $CurrentUser = [Security.Principal.WindowsIdentity]::GetCurrent().Name

    if ($CurrentUser -match '^(NT AUTHORITY\\SYSTEM|SYSTEM)$')
    {
        Write-Log ("Send-UserToast skipped ({0}): running as SYSTEM. Suffix: {1}" -f $CurrentUser, $Suffix) "INFO"
        return
    }

    try
    {
        $RegistryPath = "HKCU:\SOFTWARE\Classes\AppUserModelId\$ToastAppId"

        if (-not (Test-Path $RegistryPath))
        {
            New-Item $RegistryPath -Force | Out-Null
        }

        Set-ItemProperty $RegistryPath -Name "DisplayName" -Value $ToastAppDisplayName -Force -ErrorAction SilentlyContinue
        Set-ItemProperty $RegistryPath -Name "ShowInActionCenter" -Value 1 -Type DWord -Force -ErrorAction SilentlyContinue

        $null = [Windows.UI.Notifications.ToastNotificationManager, Windows.UI.Notifications, ContentType = WindowsRuntime]
        $null = [Windows.Data.Xml.Dom.XmlDocument, Windows.Data.Xml.Dom, ContentType = WindowsRuntime]

        $Xml = '<toast duration="long"><visual><binding template="ToastGeneric">' +
               '<image placement="appLogoOverride" src="file:///C:/ProgramData/i3/branding/i3_CharmOnly_150x150_toast.png" hint-crop="circle"/>' +
               "<text>$([Security.SecurityElement]::Escape($Title))</text>" +
               "<text>$([Security.SecurityElement]::Escape($Body))</text>" +
               '<text placement="attribution">Business Solutions</text>' +
               '</binding></visual><audio src="ms-winsoundevent:Notification.Reminder"/></toast>'

        $XmlDoc = [Windows.Data.Xml.Dom.XmlDocument]::new()
        $XmlDoc.LoadXml($Xml)
        $Toast = [Windows.UI.Notifications.ToastNotification]::new($XmlDoc)
        [Windows.UI.Notifications.ToastNotificationManager]::CreateToastNotifier($ToastAppId).Show($Toast)

        Write-Log ("Toast ({0}) shown." -f $Suffix) "SUCCESS"
        Start-Sleep -Seconds 3
    }
    catch
    {
        Write-Log ("Send-UserToast failed: {0}" -f $_.Exception.Message) "WARN"
    }
}

function Remove-Infrastructure
{
    Write-Log "Removing infrastructure..." "INFO"

    foreach ($FilePath in @($ManifestPath, $MarkerPath, $ProtocolHandlerPath, $ToastScriptPath, $ToastConfigPath))
    {
        if (Test-Path $FilePath)
        {
            Remove-Item $FilePath -Force -ErrorAction SilentlyContinue
            Write-Log ("  Removed: {0}" -f (Split-Path $FilePath -Leaf)) "INFO"
        }
    }

    foreach ($TaskName in @($InstallTaskName, $BootTaskName, $ToastTaskName))
    {
        if (Get-ScheduledTask -TaskName $TaskName -ErrorAction SilentlyContinue)
        {
            Unregister-ScheduledTask -TaskName $TaskName -Confirm:$false -ErrorAction SilentlyContinue
            Write-Log ("  Removed task: {0}" -f $TaskName) "INFO"
        }
    }

    $ProtocolRegistryPath = "HKLM:\SOFTWARE\Classes\$ProtocolName"

    if (Test-Path $ProtocolRegistryPath)
    {
        Remove-Item $ProtocolRegistryPath -Recurse -Force -ErrorAction SilentlyContinue
        Write-Log "  Removed protocol registry." "INFO"
    }

    if ($SelfPath -and (Test-Path $SelfPath))
    {
        Remove-Item $SelfPath -Force -ErrorAction SilentlyContinue
        Write-Log "  Removed self." "INFO"
    }

    Write-Log "Infrastructure removed." "INFO"
}

$ComObjects = [Collections.Generic.List[object]]::new()
$InternalExitCode = $INTERNAL_SUCCESS
$InstallSuccess = 0
$InstallFail = 0
$AlreadyInstalled = 0
$RebootCount = 0
$Status = "Unknown"

try
{
    $Mode = if ($UserInitiated) { "UserInitiated" } else { "AtStartup" }

    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1} | Mode: {2}" -f $ScriptName, $ScriptVersion, $Mode) "INFO"
    Write-Log ("Computer: {0} | PID: {1}" -f $env:COMPUTERNAME, $PID) "INFO"
    Write-Log ("User: {0}" -f [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    Write-Log "============================================================" "INFO"

    if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator))
    {
        $InternalExitCode = $INTERNAL_NOT_ADMIN
        throw "Not running as administrator."
    }

    Write-Log "Admin check passed." "INFO"

    if (-not (New-LockFile))
    {
        $InternalExitCode = $INTERNAL_ALREADY_RUNNING
        throw "Already running; lock held."
    }

    Stop-ToastTask

    if (Test-Path $ProtocolLogPath)
    {
        Write-Log "Protocol log found." "INFO"

        try
        {
            $ProtoLines = @(Get-Content $ProtocolLogPath -Tail 80 -ErrorAction Stop)
            Remove-Item $ProtocolLogPath -Force -ErrorAction SilentlyContinue

            foreach ($PLine in $ProtoLines)
            {
                Write-Log ("  proto: {0}" -f $PLine) "INFO"
            }
        }
        catch
        {
            Write-Log ("Protocol log read failed: {0}" -f $_.Exception.Message) "WARN"
        }
    }

    if (-not (Test-Path $ManifestPath))
    {
        if ($UserInitiated -and (Test-Path $MarkerPath))
        {
            try
            {
                $Marker = Get-Content $MarkerPath -Raw -ErrorAction Stop | ConvertFrom-Json

                if ($Marker.Status -eq "RebootPendingAfterInstall")
                {
                    Write-Log "Follow-up restart path." "INFO"
                    Remove-Infrastructure
                    Send-UserToast -Title "Driver Updates" -Body "Restarting in $RestartDelaySec seconds to finish driver updates. Please save your work." -Suffix "PreRestart"
                    & shutdown.exe /r /t $RestartDelaySec /c "Completing driver updates." /d p:2:17
                    Write-Log ("Restart scheduled ({0} sec)." -f $RestartDelaySec) "SUCCESS"
                    Remove-LockFile
                    [Environment]::Exit($INTERNAL_SUCCESS)
                }
            }
            catch
            {
                Write-Log ("Follow-up restart check failed: {0}" -f $_.Exception.Message) "WARN"
            }
        }

        $InternalExitCode = $INTERNAL_NO_MANIFEST
        throw "No manifest found."
    }

    $Manifest = Get-Content $ManifestPath -Raw -ErrorAction Stop | ConvertFrom-Json
    $ManifestIds = @{}

    foreach ($Entry in $Manifest.Updates)
    {
        $ManifestIds[$Entry.UpdateID] = $Entry
    }

    Write-Log ("Manifest: {0} update(s) from {1}" -f $Manifest.Updates.Count, $Manifest.CreatedAt) "INFO"

    if (-not (Get-Service wuauserv -ErrorAction SilentlyContinue | Where-Object { $_.Status -eq "Running" }))
    {
        Write-Log "Starting wuauserv..." "INFO"
        Start-Service wuauserv -ErrorAction SilentlyContinue
        Start-Sleep -Seconds 5
    }

    if (-not (Get-Service wuauserv -ErrorAction SilentlyContinue | Where-Object { $_.Status -eq "Running" }))
    {
        $InternalExitCode = $INTERNAL_WU_UNAVAILABLE
        throw "Windows Update service is not running."
    }

    Write-Log "Creating WU session..." "INFO"
    $Session = New-Object -ComObject Microsoft.Update.Session
    $Searcher = $Session.CreateUpdateSearcher()
    $ComObjects.Add($Session)
    $ComObjects.Add($Searcher)

    $SearchResult = $Searcher.Search("IsInstalled=0 and Type='Driver'")
    $UpdatesToInstall = New-Object -ComObject Microsoft.Update.UpdateColl
    $ComObjects.Add($UpdatesToInstall)

    Write-Log ("WU search: {0} result(s)." -f $SearchResult.Updates.Count) "INFO"

    for ($Index = 0; $Index -lt $SearchResult.Updates.Count; $Index++)
    {
        $Update = $SearchResult.Updates.Item($Index)

        if (-not $ManifestIds.ContainsKey($Update.Identity.UpdateID))
        {
            continue
        }

        if ($Update.IsDownloaded)
        {
            [void]$UpdatesToInstall.Add($Update)
            Write-Log ("  Matched downloaded update: {0}" -f $Update.Title) "INFO"
        }
        else
        {
            Write-Log ("  Re-downloading: {0}" -f $Update.Title) "WARN"

            if (-not $Update.EulaAccepted)
            {
                $Update.AcceptEula()
            }

            $RedownloadCollection = New-Object -ComObject Microsoft.Update.UpdateColl
            [void]$RedownloadCollection.Add($Update)
            $Redownloader = $Session.CreateUpdateDownloader()
            $Redownloader.Updates = $RedownloadCollection
            $RedownloadResult = $Redownloader.Download()

            [Runtime.InteropServices.Marshal]::ReleaseComObject($Redownloader) | Out-Null
            [Runtime.InteropServices.Marshal]::ReleaseComObject($RedownloadCollection) | Out-Null

            if ($RedownloadResult.GetUpdateResult(0).ResultCode -eq 2)
            {
                [void]$UpdatesToInstall.Add($Update)
                Write-Log "  Re-download succeeded." "SUCCESS"
            }
            else
            {
                $InstallFail++
                Write-Log ("  Re-download FAILED: {0}" -f $Update.Title) "ERROR"
            }
        }

        $ManifestIds.Remove($Update.Identity.UpdateID)
    }

    foreach ($Key in $ManifestIds.Keys)
    {
        $AlreadyInstalled++
        Write-Log ("  Already installed or no longer applicable: {0}" -f $ManifestIds[$Key].Title) "SUCCESS"
    }

    if ($UpdatesToInstall.Count -eq 0)
    {
        if ($AlreadyInstalled -gt 0 -and $InstallFail -eq 0)
        {
            $Status = "AlreadyComplete"
            Write-Log "All updates already installed." "SUCCESS"
            Remove-Infrastructure
        }
        else
        {
            $Status = "NoMatch"
            $InternalExitCode = $INTERNAL_NO_MATCHING
        }

        throw "Nothing to install."
    }

    if (-not (Wait-WUReady -MaxRetries $WUBusyRetryCount -DelaySeconds $WUBusyRetryDelaySec))
    {
        $Status = "WUBusy"
        $InternalExitCode = $INTERNAL_WU_BUSY
        throw "Windows Update stayed busy."
    }

    Write-Log ("Installing {0} update(s)..." -f $UpdatesToInstall.Count) "INFO"

    $Installer = $Session.CreateUpdateInstaller()
    $Installer.Updates = $UpdatesToInstall
    $Installer.AllowSourcePrompts = $false
    $ComObjects.Add($Installer)

    try
    {
        $Installer.ForceQuiet = $true
    }
    catch
    {
    }

    $InstallStart = Get-Date
    $InstallResult = $Installer.Install()
    $Duration = (Get-Date) - $InstallStart

    Write-Log ("Install done in {0}s - {1}" -f [math]::Round($Duration.TotalSeconds), (Get-WUResultText -Code $InstallResult.ResultCode)) "INFO"

    $Results = [Collections.Generic.List[PSCustomObject]]::new()

    for ($Index = 0; $Index -lt $UpdatesToInstall.Count; $Index++)
    {
        $Update = $UpdatesToInstall.Item($Index)
        $UpdateResult = $InstallResult.GetUpdateResult($Index)
        $RebootRequired = $UpdateResult.RebootRequired

        if ($UpdateResult.ResultCode -in @(2, 3))
        {
            $InstallSuccess++

            if ($RebootRequired)
            {
                $RebootCount++
            }

            Write-Log ("  INSTALLED ({0}): {1}" -f $(if ($RebootRequired) { 'reboot-pending' } else { 'no-reboot' }), $Update.Title) "SUCCESS"
        }
        else
        {
            $InstallFail++
            Write-Log ("  FAILED: {0} - 0x{1}" -f $Update.Title, $UpdateResult.HResult.ToString('X8')) "ERROR"
        }

        $Results.Add(
            [PSCustomObject]@{
                Title = $Update.Title
                Result = Get-WUResultText -Code $UpdateResult.ResultCode
                RebootRequired = $RebootRequired
                HResult = "0x$($UpdateResult.HResult.ToString('X8'))"
            }
        )
    }

    $PendingReboot = Test-PendingReboot
    $EffectiveReboot = $InstallResult.RebootRequired -or $PendingReboot.Pending

    Write-Log ("SUMMARY | Installed: {0} | Already: {1} | Failed: {2} | RebootPending: {3}" -f $InstallSuccess, $AlreadyInstalled, $InstallFail, $RebootCount) "INFO"
    Write-Log ("EffectiveReboot: {0} (reasons: {1})" -f $EffectiveReboot, ($PendingReboot.Reasons -join ', ')) "INFO"

    if ($InstallFail -gt 0 -and $InstallSuccess -eq 0)
    {
        $Status = "Failed"
        $InternalExitCode = $INTERNAL_TOTAL_FAIL
    }
    elseif ($InstallFail -gt 0)
    {
        $Status = "Partial"
        $InternalExitCode = $INTERNAL_PARTIAL
    }
    else
    {
        $Status = "Success"
        $InternalExitCode = $INTERNAL_SUCCESS
    }

    Write-RunSummary @{
        Script = $ScriptName
        Version = $ScriptVersion
        Mode = $Mode
        Status = $Status
        Installed = $InstallSuccess
        Already = $AlreadyInstalled
        Failed = $InstallFail
        RebootPending = $RebootCount
        RebootRequired = $EffectiveReboot
        DurSec = [math]::Round($Duration.TotalSeconds)
        Results = @($Results)
        ExitCode = $InternalExitCode
        Timestamp = (Get-Date).ToString("o")
    }

    if ($InstallSuccess -gt 0)
    {
        if ($UserInitiated)
        {
            Write-Log "UserInitiated: cleanup and restart." "INFO"
            Remove-Infrastructure
            Send-UserToast -Title "Driver Updates" -Body "$InstallSuccess driver update(s) installed. Restarting in $RestartDelaySec seconds. Please save your work." -Suffix "PreRestart"
            & shutdown.exe /r /t $RestartDelaySec /c "$InstallSuccess driver update(s) installed." /d p:2:17
            Write-Log ("Restart scheduled ({0} sec)." -f $RestartDelaySec) "SUCCESS"
        }
        else
        {
            Write-Log "AtStartup: evaluating reboot." "INFO"

            if ($EffectiveReboot)
            {
                Write-Log ("Reboot required for {0} update(s)." -f $RebootCount) "WARN"

                @{
                    Status = "RebootPendingAfterInstall"
                    InstalledThisRun = $InstallSuccess
                    StillNeedReboot = $RebootCount
                    ComputerName = $env:COMPUTERNAME
                    UpdatedAt = (Get-Date).ToString("o")
                } |
                    ConvertTo-Json -Depth 10 | Out-File $MarkerPath -Encoding UTF8 -Force

                if (Test-Path $ManifestPath)
                {
                    Remove-Item $ManifestPath -Force -ErrorAction SilentlyContinue
                    Write-Log "Manifest cleared." "INFO"
                }

                try
                {
                    Start-ScheduledTask -TaskName $ToastTaskName -ErrorAction Stop
                    Write-Log "Toast kicked." "INFO"
                }
                catch
                {
                    Write-Log ("Toast kick failed: {0}" -f $_.Exception.Message) "WARN"
                }
            }
            else
            {
                Write-Log "No reboot required. Cleaning up." "SUCCESS"
                Remove-Infrastructure
                Send-UserToast -Title "Driver Updates" -Body "$InstallSuccess driver update(s) installed. No restart needed." -Suffix "Complete"
            }
        }
    }
    elseif ($AlreadyInstalled -gt 0 -and $InstallFail -eq 0)
    {
        Write-Log "All already installed. Cleaning up." "SUCCESS"
        Remove-Infrastructure
    }
    else
    {
        Write-Log "Install failed or no match. Retaining infrastructure." "WARN"
    }
}
catch
{
    Write-Log ("ERROR: {0}" -f $_.Exception.Message) "ERROR"

    if ($_.ScriptStackTrace)
    {
        Write-Log ("Stack: {0}" -f $_.ScriptStackTrace) "ERROR"
    }

    if ($InternalExitCode -eq $INTERNAL_SUCCESS)
    {
        $InternalExitCode = $INTERNAL_CRITICAL
    }

    if ($Status -eq "Unknown")
    {
        $Status = "CriticalFailure"
    }

    Write-RunSummary @{
        Script = $ScriptName
        Version = $ScriptVersion
        Status = $Status
        Error = $_.Exception.Message
        ExitCode = $InternalExitCode
        Timestamp = (Get-Date).ToString("o")
    }
}
finally
{
    if ($ComObjects.Count -gt 0)
    {
        Clear-ComObjects -Objects $ComObjects
    }

    Remove-LockFile
    Write-Log ("Exit: {0}" -f $InternalExitCode) "INFO"
    [Environment]::Exit($InternalExitCode)
}
'@
    Set-Content -Path $InstallerScriptPath -Value $Content -Encoding UTF8 -Force
    $FileSize = (Get-Item -Path $InstallerScriptPath).Length
    Write-Log ("Installer script written: {0} ({1} bytes, v3.5.5 embedded)" -f (Split-Path $InstallerScriptPath -Leaf), $FileSize) "SUCCESS"
}

function Write-ToastScript
{
    $Content = @'
<#
.SYNOPSIS
    Shows an adaptive Windows toast notification for i3 driver updates.

.DESCRIPTION
    Reads local state files to determine whether to present an install/restart
    notification to the interactive user. Handles the button click in-process
    via the Activated event so no custom protocol handler is required.

.AUTHOR
    Ken Kruis

.VERSION
    1.4.0
#>

[CmdletBinding()]
param
(
    [string]$BasePath = "C:\ProgramData\i3",
    [int]$LogRetentionDays = 30,
    [switch]$EnableWpfFallback = $true,
    [switch]$Silent
)

$ScriptName = "Show-DriverUpdateToast"
$ScriptVersion = "1.4.0"
$RunStamp = Get-Date -Format "yyyyMMdd_HHmmss"

$LogPath = Join-Path $BasePath "logs"
$UserStatePath = Join-Path $BasePath "UserState"
$ConfigPath = Join-Path $BasePath "DriverUpdateToast.config.json"
$ManifestPath = Join-Path $BasePath "DriverUpdateManifest.json"
$MarkerPath = Join-Path $BasePath "DriverUpdate_RebootRequired.marker.json"
$StatusPath = Join-Path $UserStatePath "DriverUpdateToast.status.json"
$HeartbeatPath = Join-Path $UserStatePath "DriverUpdateToast.started.txt"
$LogFile = Join-Path $UserStatePath "${ScriptName}_${RunStamp}.log"

$ToastAppId = "i3ITManagement.DriverUpdate"
$ToastAppDisplayName = "Business Solutions"
$InstallTaskName = "i3_DriverInstallAndRestart"

$Caption = "i3 Updates Available"
$Mode = $null
$BodyText = ""
$PrimaryBtnText = ""
$UpdateCount = 0

$Status = [ordered]@{
    ScriptName = $ScriptName
    ScriptVersion = $ScriptVersion
    ComputerName = $env:COMPUTERNAME
    UserName = [Security.Principal.WindowsIdentity]::GetCurrent().Name
    StartedAt = (Get-Date).ToString("o")
    CompletedAt = $null
    Caption = $Caption
    Mode = $null
    ManifestFound = $false
    MarkerFound = $false
    ManifestUpdateCount = 0
    AppIdRegistered = $false
    ToastAttempted = $false
    ToastShowCallSucceeded = $false
    ToastActivated = $false
    ToastDismissed = $false
    WpfFallbackAttempted = $false
    WpfFallbackShown = $false
    ActionableStateFound = $false
    ExitReason = $null
    Error = $null
}

function Write-Log
{
    param
    (
        [string]$Message,
        [string]$Level = "INFO"
    )

    $Line = "{0} [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level.ToUpper(), $Message

    if (-not $Silent)
    {
        Write-Host $Line
    }

    try
    {
        if (-not (Test-Path -Path $UserStatePath))
        {
            New-Item -Path $UserStatePath -ItemType Directory -Force | Out-Null
        }

        Add-Content -Path $LogFile -Value $Line -ErrorAction Stop
    }
    catch
    {
    }
}

function Write-Status
{
    try
    {
        $Status.CompletedAt = (Get-Date).ToString("o")
        $Status | ConvertTo-Json -Depth 10 | Out-File -FilePath $StatusPath -Encoding UTF8 -Force
    }
    catch
    {
    }
}

function Write-Heartbeat
{
    try
    {
        if (-not (Test-Path -Path $UserStatePath))
        {
            New-Item -Path $UserStatePath -ItemType Directory -Force | Out-Null
        }

        $Content = "Started: $(Get-Date -Format 'o')`nScript: $ScriptName v$ScriptVersion`nUser: $($Status.UserName)`nComputer: $($Status.ComputerName)"
        Set-Content -Path $HeartbeatPath -Value $Content -Encoding UTF8 -Force
    }
    catch
    {
    }
}

function Remove-OldLogs
{
    try
    {
        if (-not (Test-Path -Path $UserStatePath))
        {
            return
        }

        $Cutoff = (Get-Date).AddDays(-$LogRetentionDays)

        Get-ChildItem -Path $UserStatePath -File -ErrorAction SilentlyContinue |
            Where-Object { $_.LastWriteTime -lt $Cutoff } |
            ForEach-Object { Remove-Item -Path $_.FullName -Force -ErrorAction SilentlyContinue }
    }
    catch
    {
    }
}

function Set-ExitState
{
    param
    (
        [string]$Reason,
        [string]$ErrorMessage = $null
    )

    $Status.ExitReason = $Reason

    if ($ErrorMessage)
    {
        $Status.Error = $ErrorMessage
    }

    Write-Status
}

function Register-ToastAppId
{
    param
    (
        [string]$AppId,
        [string]$DisplayName
    )

    try
    {
        $HkcuPath = "HKCU:\SOFTWARE\Classes\AppUserModelId\$AppId"

        if (-not (Test-Path -Path $HkcuPath))
        {
            New-Item -Path $HkcuPath -Force | Out-Null
        }

        Set-ItemProperty -Path $HkcuPath -Name "DisplayName" -Value $DisplayName -Force
        Set-ItemProperty -Path $HkcuPath -Name "ShowInSettings" -Value 1 -Type DWord -Force
        Set-ItemProperty -Path $HkcuPath -Name "ShowInActionCenter" -Value 1 -Type DWord -Force
        Set-ItemProperty -Path $HkcuPath -Name "AllowContentAboveLock" -Value 0 -Type DWord -Force

        try
        {
            $HklmPath = "HKLM:\SOFTWARE\Classes\AppUserModelId\$AppId"

            if (-not (Test-Path -Path $HklmPath))
            {
                New-Item -Path $HklmPath -Force | Out-Null
            }

            Set-ItemProperty -Path $HklmPath -Name "DisplayName" -Value $DisplayName -Force
            Set-ItemProperty -Path $HklmPath -Name "ShowInSettings" -Value 1 -Type DWord -Force
            Set-ItemProperty -Path $HklmPath -Name "ShowInActionCenter" -Value 1 -Type DWord -Force
            Set-ItemProperty -Path $HklmPath -Name "IconUri" -Value "C:\ProgramData\i3\branding\i3_CharmOnly_150x150_toast.png" -Force
        }
        catch
        {
            Write-Log ("HKLM AppId write skipped: {0}" -f $_.Exception.Message) "INFO"
        }

        $NotifPath = "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Notifications\Settings\$AppId"

        if (-not (Test-Path -Path $NotifPath))
        {
            New-Item -Path $NotifPath -Force | Out-Null
        }

        $Existing = Get-ItemProperty -Path $NotifPath -Name "Enabled" -ErrorAction SilentlyContinue

        if ($null -eq $Existing -or $Existing.Enabled -ne 1)
        {
            Set-ItemProperty -Path $NotifPath -Name "Enabled" -Value 1 -Type DWord -Force
            Write-Log ("Notification setting Enabled set to 1 for AppId: {0}" -f $AppId) "INFO"
        }

        Write-Log ("AppId registered: {0} ({1})" -f $AppId, $DisplayName) "SUCCESS"
        return $true
    }
    catch
    {
        Write-Log ("AppId registration failed: {0}" -f $_.Exception.Message) "WARN"
        return $false
    }
}

function Invoke-InstallTask
{
    $Triggered = $false

    # Try COM first
    $Sched   = $null
    $Folder  = $null
    $TaskObj = $null

    try
    {
        Write-Log ("Attempting COM task trigger: {0}" -f $InstallTaskName) "INFO"
        $Sched   = New-Object -ComObject Schedule.Service
        $Sched.Connect()
        $Folder  = $Sched.GetFolder("\")
        $TaskObj = $Folder.GetTask($InstallTaskName)
        $null    = $TaskObj.Run($null)
        $Triggered = $true
        Write-Log "COM task trigger succeeded." "SUCCESS"
    }
    catch
    {
        Write-Log ("COM task trigger failed: {0}" -f $_.Exception.Message) "WARN"
    }
    finally
    {
        foreach ($Obj in @($TaskObj, $Folder, $Sched))
        {
            if ($Obj)
            {
                try { [Runtime.InteropServices.Marshal]::ReleaseComObject($Obj) | Out-Null } catch { }
            }
        }
    }

    # schtasks.exe fallback
    if (-not $Triggered)
    {
        try
        {
            Write-Log "Trying schtasks.exe fallback." "WARN"
            $Output   = & schtasks.exe /Run /TN "\$InstallTaskName" 2>&1
            $ExitCode = $LASTEXITCODE
            $Output | ForEach-Object { Write-Log ("schtasks: {0}" -f $_) "INFO" }

            if ($ExitCode -eq 0)
            {
                $Triggered = $true
                Write-Log "schtasks.exe trigger succeeded." "SUCCESS"
            }
            else
            {
                Write-Log ("schtasks.exe exit code: {0}" -f $ExitCode) "ERROR"
            }
        }
        catch
        {
            Write-Log ("schtasks.exe fallback failed: {0}" -f $_.Exception.Message) "ERROR"
        }
    }

    if (-not $Triggered)
    {
        Write-Log "All trigger methods failed." "ERROR"
    }

    return $Triggered
}

function Show-WpfFallback
{
    param
    (
        [string]$WindowTitle,
        [string]$MessageText,
        [string]$ButtonText
    )

    $Status.WpfFallbackAttempted = $true
    Write-Log "Attempting WPF fallback popup." "WARN"

    try
    {
        Add-Type -AssemblyName PresentationFramework -ErrorAction Stop
        Add-Type -AssemblyName PresentationCore -ErrorAction Stop
        Add-Type -AssemblyName WindowsBase -ErrorAction Stop

        $Xaml = @"
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="$([Security.SecurityElement]::Escape($WindowTitle))"
        Height="240"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="$([Security.SecurityElement]::Escape($WindowTitle))" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" TextWrapping="Wrap" />
        <TextBlock Grid.Row="1" Text="$([Security.SecurityElement]::Escape($MessageText))" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Top" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Name="LaterButton" Width="110" Height="34" Margin="0,0,10,0" Content="Later" />
            <Button Name="ActionButton" Width="180" Height="34" Content="$([Security.SecurityElement]::Escape($ButtonText))" />
        </StackPanel>
    </Grid>
</Window>
"@

        $Reader = New-Object System.Xml.XmlNodeReader ([xml]$Xaml)
        $Window = [Windows.Markup.XamlReader]::Load($Reader)
        $LaterButton  = $Window.FindName("LaterButton")
        $ActionButton = $Window.FindName("ActionButton")

        $LaterButton.Add_Click({
            $Window.Tag = "Later"
            $Window.Close()
        })

        $ActionButton.Add_Click({
            $Window.Tag = "Action"
            $Window.Close()
        })

        $null = $Window.ShowDialog()
        $Status.WpfFallbackShown = $true
        Write-Log "WPF fallback popup displayed and closed." "SUCCESS"

        if ($Window.Tag -eq "Action")
        {
            Write-Log "User clicked action in WPF fallback." "SUCCESS"
            Invoke-InstallTask | Out-Null
        }
        else
        {
            Write-Log "User dismissed WPF fallback with Later." "INFO"
        }

        return $true
    }
    catch
    {
        Write-Log ("WPF fallback failed: {0}" -f $_.Exception.Message) "ERROR"
        return $false
    }
}

try
{
    Remove-OldLogs

    foreach ($Directory in @($BasePath, $UserStatePath))
    {
        if (-not (Test-Path -Path $Directory))
        {
            New-Item -Path $Directory -ItemType Directory -Force | Out-Null
        }
    }

    Write-Heartbeat

    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1}" -f $ScriptName, $ScriptVersion) "INFO"
    Write-Log ("Computer: {0}" -f $env:COMPUTERNAME) "INFO"
    Write-Log ("User: {0}" -f [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    Write-Log ("AppId: {0}" -f $ToastAppId) "INFO"
    Write-Log "============================================================" "INFO"

    $AppIdOk = Register-ToastAppId -AppId $ToastAppId -DisplayName $ToastAppDisplayName
    $Status.AppIdRegistered = $AppIdOk

    if (Test-Path -Path $ConfigPath)
    {
        try
        {
            $Config = Get-Content -Path $ConfigPath -Raw -ErrorAction Stop | ConvertFrom-Json

            if ($Config.Caption)
            {
                $Caption = [string]$Config.Caption
                $Status.Caption = $Caption
            }

            Write-Log ("Config loaded. Caption: '{0}'" -f $Caption) "INFO"
        }
        catch
        {
            Write-Log ("Config read failed: {0}" -f $_.Exception.Message) "WARN"
        }
    }
    else
    {
        Write-Log "Config not found - using default caption." "INFO"
    }

    if (Test-Path -Path $ManifestPath)
    {
        $Status.ManifestFound = $true
        Write-Log ("Manifest found: {0}" -f $ManifestPath) "INFO"

        try
        {
            $Manifest = Get-Content -Path $ManifestPath -Raw -ErrorAction Stop | ConvertFrom-Json
            $UpdateCount = if ($Manifest.Updates) { @($Manifest.Updates).Count } else { 0 }
            $Status.ManifestUpdateCount = $UpdateCount
            Write-Log ("Manifest update count: {0}" -f $UpdateCount) "INFO"

            if ($UpdateCount -gt 0)
            {
                $Mode = "Install"
                $BodyText = "$UpdateCount driver/firmware update(s) have been downloaded and are ready to install. Your computer will need to restart."
                $PrimaryBtnText = "Install & Restart Now"
            }
        }
        catch
        {
            Write-Log ("Manifest parse failed: {0}" -f $_.Exception.Message) "WARN"
        }
    }
    else
    {
        Write-Log "Manifest not found." "INFO"
    }

    if ((-not $Mode) -and (Test-Path -Path $MarkerPath))
    {
        $Status.MarkerFound = $true
        Write-Log ("Marker found: {0}" -f $MarkerPath) "INFO"

        try
        {
            $Marker = Get-Content -Path $MarkerPath -Raw -ErrorAction Stop | ConvertFrom-Json

            if ($Marker.Status -eq "RebootPendingAfterInstall")
            {
                $InstalledValue = if ($Marker.PSObject.Properties.Name -contains "InstalledThisRun" -and $Marker.InstalledThisRun) { [string]$Marker.InstalledThisRun } else { "Some" }
                $PendingValue   = if ($Marker.PSObject.Properties.Name -contains "StillNeedReboot"  -and $Marker.StillNeedReboot)  { [string]$Marker.StillNeedReboot  } else { "some" }
                $Mode = "Restart"
                $BodyText = "$InstalledValue driver update(s) were installed, but $PendingValue still need a restart to finish."
                $PrimaryBtnText = "Restart Now"
            }
            else
            {
                Write-Log ("Marker status '{0}' is not actionable." -f $Marker.Status) "INFO"
            }
        }
        catch
        {
            Write-Log ("Marker parse failed: {0}" -f $_.Exception.Message) "WARN"
        }
    }
    else
    {
        if (-not (Test-Path -Path $MarkerPath))
        {
            Write-Log "Marker not found." "INFO"
        }
    }

    if (-not $Mode)
    {
        $Status.ActionableStateFound = $false
        $Status.Mode = "None"
        Write-Log "No actionable state found. Exiting without notification." "INFO"
        Set-ExitState -Reason "NoActionableState"
        exit 0
    }

    $Status.ActionableStateFound = $true
    $Status.Mode = $Mode

    Write-Log ("Mode: {0} | Button: {1}" -f $Mode, $PrimaryBtnText) "SUCCESS"
    Write-Log ("Body: {0}" -f $BodyText) "INFO"

    try
    {
        $Status.ToastAttempted = $true

        $null = [Windows.UI.Notifications.ToastNotificationManager, Windows.UI.Notifications, ContentType = WindowsRuntime]
        $null = [Windows.Data.Xml.Dom.XmlDocument, Windows.Data.Xml.Dom, ContentType = WindowsRuntime]

        # activationType="foreground" delivers the click back to this process
        # via the Activated event rather than launching an external handler.
        # This is reliable from toast context where custom protocols are blocked.
        $ToastXml = @"
<toast duration="long" scenario="reminder">
    <visual>
        <binding template="ToastGeneric">
            <image placement="appLogoOverride" src="file:///C:/ProgramData/i3/branding/i3_CharmOnly_150x150_toast.png" hint-crop="circle"/>
            <text>$([Security.SecurityElement]::Escape($Caption))</text>
            <text>$([Security.SecurityElement]::Escape($BodyText))</text>
            <text placement="attribution">Business Solutions</text>
        </binding>
    </visual>
    <actions>
        <action content="$([Security.SecurityElement]::Escape($PrimaryBtnText))" activationType="foreground" arguments="action=install"/>
        <action content="Later" activationType="system" arguments="dismiss"/>
    </actions>
    <audio src="ms-winsoundevent:Notification.Reminder"/>
</toast>
"@

        $XmlDoc = [Windows.Data.Xml.Dom.XmlDocument]::new()
        $XmlDoc.LoadXml($ToastXml)

        $Toast = [Windows.UI.Notifications.ToastNotification]::new($XmlDoc)

        $script:ToastActivated = $false
        $script:ToastDismissed = $false

        $Toast.add_Activated({
            $script:ToastActivated = $true
            $Status.ToastActivated = $true
            Write-Log "Toast button activated - triggering install task." "SUCCESS"
            Invoke-InstallTask | Out-Null
        })

        $Toast.add_Dismissed({
            $script:ToastDismissed = $true
            $Status.ToastDismissed = $true
            Write-Log "Toast dismissed by user." "INFO"
        })

        $Toast.add_Failed({
            $script:ToastDismissed = $true
            Write-Log "Toast Failed event fired." "WARN"
        })

        Write-Log ("Calling CreateToastNotifier('{0}').Show()..." -f $ToastAppId) "INFO"
        [Windows.UI.Notifications.ToastNotificationManager]::CreateToastNotifier($ToastAppId).Show($Toast)
        $Status.ToastShowCallSucceeded = $true
        Write-Log "Toast Show() returned - waiting for user action (up to 10 min)." "SUCCESS"

        # Keep process alive so the Activated event can fire.
        # The scheduled task will show as Running until the user acts or the deadline passes.
        $Deadline = (Get-Date).AddMinutes(10)
        while (-not $script:ToastActivated -and -not $script:ToastDismissed -and (Get-Date) -lt $Deadline)
        {
            Start-Sleep -Seconds 2
        }

        $WaitOutcome = if ($script:ToastActivated) { "UserClickedInstall" } elseif ($script:ToastDismissed) { "UserDismissed" } else { "WaitTimeout" }
        Write-Log ("Wait complete. Activated={0} Dismissed={1} Outcome={2}" -f $script:ToastActivated, $script:ToastDismissed, $WaitOutcome) "INFO"
        Set-ExitState -Reason $WaitOutcome
        exit 0
    }
    catch
    {
        $ErrorMessage = $_.Exception.Message
        Write-Log ("Toast display failed: {0}" -f $ErrorMessage) "ERROR"

        if ($EnableWpfFallback)
        {
            $FallbackShown = Show-WpfFallback -WindowTitle $Caption -MessageText $BodyText -ButtonText $PrimaryBtnText

            if ($FallbackShown)
            {
                Set-ExitState -Reason "ToastFailed_WpfFallbackShown" -ErrorMessage $ErrorMessage
                exit 0
            }
        }

        Set-ExitState -Reason "ToastFailed_NoFallbackShown" -ErrorMessage $ErrorMessage
        exit 0
    }
}
catch
{
    $FatalError = $_.Exception.Message
    Write-Log ("Unhandled failure: {0}" -f $FatalError) "ERROR"
    Set-ExitState -Reason "UnhandledFailure" -ErrorMessage $FatalError
    exit 0
}
'@
    Set-Content -Path $ToastScriptPath -Value $Content -Encoding UTF8 -Force
    $FileSize = (Get-Item -Path $ToastScriptPath).Length
    Write-Log ("Toast script written: {0} ({1} bytes, v1.4.0 embedded)" -f (Split-Path $ToastScriptPath -Leaf), $FileSize) "SUCCESS"
}

