function Write-ProtocolHandler
{
    $Content = @'
[CmdletBinding()]
param
(
    [string]$ProtocolArg
)

$BasePath = "C:\ProgramData\i3"
$UserStatePath = Join-Path $BasePath "UserState"
$LogFile = Join-Path $UserStatePath "Request-DriverInstall.log"
$FallbackLog = Join-Path $env:TEMP "Request-DriverInstall_fallback.log"
$TaskName = "i3_DriverInstallAndRestart"
$ScriptName = "Request-DriverInstall"
$ScriptVersion = "1.1.0"
$InternalExit = 0

function Write-Log
{
    param
    (
        [string]$Message,
        [string]$Level = "INFO"
    )

    $Line = "{0} [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $Level.ToUpper(), $Message
    $WrotePrimary = $false

    try
    {
        if (-not (Test-Path -Path $UserStatePath))
        {
            New-Item -Path $UserStatePath -ItemType Directory -Force | Out-Null
        }

        Add-Content -Path $LogFile -Value $Line -ErrorAction Stop
        $WrotePrimary = $true
    }
    catch
    {
        try
        {
            Add-Content -Path $FallbackLog -Value $Line -ErrorAction SilentlyContinue
        }
        catch
        {
        }
    }

    if (-not $WrotePrimary)
    {
        try
        {
            Add-Content -Path $FallbackLog -Value ("{0} [WARN] Primary log write failed. Fallback log used: {1}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"), $FallbackLog) -ErrorAction SilentlyContinue
        }
        catch
        {
        }
    }
}

function Invoke-TaskViaCom
{
    param
    (
        [string]$Name
    )

    $Scheduler = $null
    $Folder = $null
    $Task = $null

    try
    {
        Write-Log ("Attempting COM task trigger: {0}" -f $Name) "INFO"

        $Scheduler = New-Object -ComObject Schedule.Service
        $Scheduler.Connect()
        $Folder = $Scheduler.GetFolder("\")
        $Task = $Folder.GetTask($Name)

        Write-Log "COM task lookup succeeded." "SUCCESS"
        $null = $Task.Run($null)
        Write-Log "COM task Run() call succeeded." "SUCCESS"
        return $true
    }
    catch
    {
        Write-Log ("COM task trigger failed: {0}" -f $_.Exception.Message) "ERROR"
        return $false
    }
    finally
    {
        foreach ($Object in @($Task, $Folder, $Scheduler))
        {
            if ($Object)
            {
                try
                {
                    [Runtime.InteropServices.Marshal]::ReleaseComObject($Object) | Out-Null
                }
                catch
                {
                }
            }
        }
    }
}

function Invoke-TaskViaSchTasks
{
    param
    (
        [string]$Name
    )

    try
    {
        Write-Log ("Attempting schtasks.exe trigger: {0}" -f $Name) "INFO"

        $Output = & schtasks.exe /Run /TN "\$Name" 2>&1
        $ExitCode = $LASTEXITCODE

        foreach ($Line in @($Output))
        {
            Write-Log ("schtasks: {0}" -f $Line) "INFO"
        }

        Write-Log ("schtasks.exe exit code: {0}" -f $ExitCode) "INFO"

        if ($ExitCode -eq 0)
        {
            Write-Log "schtasks.exe task trigger succeeded." "SUCCESS"
            return $true
        }

        return $false
    }
    catch
    {
        Write-Log ("schtasks.exe task trigger failed: {0}" -f $_.Exception.Message) "ERROR"
        return $false
    }
}

try
{
    Write-Log "============================================================" "INFO"
    Write-Log ("Script: {0} v{1}" -f $ScriptName, $ScriptVersion) "INFO"
    Write-Log ("Computer: {0}" -f $env:COMPUTERNAME) "INFO"
    Write-Log ("User: {0}" -f [Security.Principal.WindowsIdentity]::GetCurrent().Name) "INFO"
    Write-Log ("ProtocolArg: {0}" -f $ProtocolArg) "INFO"
    Write-Log ("PrimaryLog: {0}" -f $LogFile) "INFO"
    Write-Log ("FallbackLog: {0}" -f $FallbackLog) "INFO"
    Write-Log ("Target task: {0}" -f $TaskName) "INFO"

    try
    {
        $WhoAmI = & whoami.exe /user 2>&1
        foreach ($Line in @($WhoAmI))
        {
            Write-Log ("whoami /user: {0}" -f $Line) "INFO"
        }

        $Groups = & whoami.exe /groups 2>&1
        foreach ($Line in @($Groups))
        {
            Write-Log ("whoami /groups: {0}" -f $Line) "INFO"
        }
    }
    catch
    {
        Write-Log ("whoami logging failed: {0}" -f $_.Exception.Message) "WARN"
    }

    $Triggered = Invoke-TaskViaCom -Name $TaskName

    if (-not $Triggered)
    {
        Write-Log "COM trigger failed. Trying schtasks.exe fallback." "WARN"
        $Triggered = Invoke-TaskViaSchTasks -Name $TaskName
    }

    if ($Triggered)
    {
        Write-Log "Task trigger succeeded." "SUCCESS"
        $InternalExit = 0
    }
    else
    {
        Write-Log "Task trigger failed by all methods." "ERROR"
        $InternalExit = 1
    }
}
catch
{
    $InternalExit = 1
    Write-Log ("Unhandled failure: {0}" -f $_.Exception.Message) "ERROR"

    if ($_.ScriptStackTrace)
    {
        Write-Log ("Stack: {0}" -f $_.ScriptStackTrace) "ERROR"
    }
}
finally
{
    Write-Log ("Exit: {0}" -f $InternalExit) "INFO"
    [Environment]::Exit($InternalExit)
}
'@
    Set-Content -Path $ProtocolHandlerPath -Value $Content -Force -Encoding UTF8
    Write-Log "Protocol handler written (v1.1.0 with UserState logging, COM trigger, and schtasks fallback)." "INFO"
}

