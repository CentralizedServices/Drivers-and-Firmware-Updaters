        0       { return "NotStarted" }
        1       { return "InProgress" }
        2       { return "Succeeded" }
        3       { return "SucceededWithErrors" }
        4       { return "Failed" }
        5       { return "Aborted" }
        default { return "Unknown($Code)" }
    }
}

function Get-ActiveConsoleUser
{
    try
    {
        $CS = Get-CimInstance Win32_ComputerSystem -ErrorAction SilentlyContinue
        if ($CS.UserName) { return $CS.UserName }
    }
    catch { }

    try
    {
        $QueryUserOutput = query user 2>$null
        if ($QueryUserOutput)
        {
            foreach ($Line in $QueryUserOutput)
            {
                if ($Line -match '^\s*([^\s>]+).*\sActive\s') { return $matches[1] }
            }
        }
    }
    catch { }

    try
    {
        $ExplorerProcess = Get-Process explorer -IncludeUserName -ErrorAction SilentlyContinue |
            Sort-Object StartTime -Descending |
            Select-Object -First 1

        if ($ExplorerProcess.UserName) { return $ExplorerProcess.UserName }
    }
    catch { }

    return $null
}

# ============================================================
# PARSE VALIDATION
