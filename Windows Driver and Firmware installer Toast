function New-LockFile
{
    try
    {
        $Data   = @{ ScriptName = $ScriptName; PID = $PID; Computer = $env:COMPUTERNAME; CreatedAt = (Get-Date).ToString("o"); Mode = if ($UserInitiated) { "UserInitiated" } else { "AtStartup" } }
        $Bytes  = [Text.Encoding]::UTF8.GetBytes(($Data | ConvertTo-Json -Depth 5))
        $Stream = [IO.File]::Open($LockFile, [IO.FileMode]::CreateNew, [IO.FileAccess]::Write, [IO.FileShare]::None)
        try
        {
            $Stream.Write($Bytes, 0, $Bytes.Length)
            $Stream.Flush()
        }
        finally
        {
            $Stream.Close()
            $Stream.Dispose()
        }
        return $true
    }
    catch [IO.IOException]
    {
        try
        {
            $Ex = Get-Content $LockFile -Raw -ErrorAction Stop | ConvertFrom-Json
            if (((Get-Date) - [datetime]$Ex.CreatedAt).TotalHours -gt 2)
            {
                Write-Log "Stale lock (>2h). Clearing." "WARN"
                Remove-Item $LockFile -Force -ErrorAction SilentlyContinue
                return (New-LockFile)
            }
            Write-Log "Lock held by PID $($Ex.PID) since $($Ex.CreatedAt)." "WARN"
        }
        catch { }
        return $false
    }
    catch { return $false }
}

