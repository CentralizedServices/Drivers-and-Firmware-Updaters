function Write-ProtocolHandler
{
    $Content = @"
@echo off
setlocal

set "LogPath=C:\ProgramData\i3\logs\Request-DriverInstall.log"
set "ScriptPath=C:\ProgramData\i3\Install-DriversAndRestart.ps1"

if not exist "C:\ProgramData\i3\logs" mkdir "C:\ProgramData\i3\logs" >nul 2>&1

echo %date% %time% [INFO] Protocol handler invoked by %USERNAME% >> "%LogPath%"

if not exist "%ScriptPath%" (
    echo %date% %time% [ERROR] Install script not found: %ScriptPath% >> "%LogPath%"
    exit /b 1
)

echo %date% %time% [INFO] Launching Install-DriversAndRestart.ps1 directly as %USERNAME% >> "%LogPath%"

powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "%ScriptPath%" -UserInitiated >> "%LogPath%" 2>&1

set "PS_EXIT=%ERRORLEVEL%"
echo %date% %time% [INFO] PowerShell exit code: %PS_EXIT% >> "%LogPath%"

exit /b %PS_EXIT%
"@

    Set-Content -Path $ProtocolHandlerPath -Value $Content -Force -Encoding ASCII
    Write-Log "Protocol handler written." "INFO"
}

